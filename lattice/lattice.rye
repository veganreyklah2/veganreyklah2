//! lattice/lattice.rye — Lattice lap 19 selftest (ops through exp · log).
//!
//!   rye build lattice/lattice.rye -femit-bin=lattice/bin/lattice
//!   lattice/bin/lattice selftest

const std = @import("std");
const assert = std.debug.assert;
const print = std.debug.print;
const lc = @import("lattice_core.rye");

const lattice_version = "20260710.213317";

fn welcome_add() !void {
    var a = try lc.Matrix.init(2, 2);
    a.set(0, 0, 1);
    a.set(0, 1, 2);
    a.set(1, 0, 3);
    a.set(1, 1, 4);

    var b = try lc.Matrix.init(2, 2);
    b.set(0, 0, 10);
    b.set(0, 1, 20);
    b.set(1, 0, 30);
    b.set(1, 1, 40);

    var c = try lc.Matrix.init(2, 2);
    try lc.add(&a, &b, &c);
    assert(c.at(0, 0) == 11);
    assert(c.at(1, 1) == 44);
    print("lattice: add 2x2 green — c00={d} c11={d}\n", .{ c.at(0, 0), c.at(1, 1) });
}

fn welcome_matmul() !void {
    var a = try lc.Matrix.init(2, 2);
    a.set(0, 0, 1);
    a.set(0, 1, 2);
    a.set(1, 0, 3);
    a.set(1, 1, 4);

    var b = try lc.Matrix.init(2, 2);
    b.set(0, 0, 5);
    b.set(0, 1, 6);
    b.set(1, 0, 7);
    b.set(1, 1, 8);

    var c = try lc.Matrix.init(2, 2);
    try lc.matmul(&a, &b, &c);
    assert(c.at(0, 0) == 19);
    assert(c.at(0, 1) == 22);
    assert(c.at(1, 0) == 43);
    assert(c.at(1, 1) == 50);
    print("lattice: matmul 2x2 green — c00={d} c11={d}\n", .{ c.at(0, 0), c.at(1, 1) });
}

fn welcome_reshape() !void {
    var a = try lc.Matrix.init(2, 3);
    a.set(0, 0, 1);
    a.set(0, 1, 2);
    a.set(0, 2, 3);
    a.set(1, 0, 4);
    a.set(1, 1, 5);
    a.set(1, 2, 6);

    var b = try lc.Matrix.init(3, 2);
    try lc.reshape(&a, &b);
    assert(b.at(0, 0) == 1);
    assert(b.at(0, 1) == 2);
    assert(b.at(1, 0) == 3);
    assert(b.at(1, 1) == 4);
    assert(b.at(2, 0) == 5);
    assert(b.at(2, 1) == 6);
    print("lattice: reshape 2x3→3x2 green — b00={d} b21={d}\n", .{ b.at(0, 0), b.at(2, 1) });
}

fn welcome_reduce_sum() !void {
    var a = try lc.Matrix.init(2, 2);
    a.set(0, 0, 1);
    a.set(0, 1, 2);
    a.set(1, 0, 3);
    a.set(1, 1, 4);
    var out = try lc.Matrix.init(1, 1);
    try lc.reduce_sum(&a, &out);
    assert(out.at(0, 0) == 10);
    print("lattice: reduce_sum 2x2 green — sum={d}\n", .{out.at(0, 0)});
}

fn welcome_reduce_mean() !void {
    var a = try lc.Matrix.init(2, 2);
    a.set(0, 0, 1);
    a.set(0, 1, 2);
    a.set(1, 0, 3);
    a.set(1, 1, 4);
    var out = try lc.Matrix.init(1, 1);
    try lc.reduce_mean(&a, &out);
    assert(out.at(0, 0) == 2.5);
    print("lattice: reduce_mean 2x2 green — mean={d}\n", .{out.at(0, 0)});
}

fn welcome_scale() !void {
    var a = try lc.Matrix.init(2, 2);
    a.set(0, 0, 1);
    a.set(0, 1, 2);
    a.set(1, 0, 3);
    a.set(1, 1, 4);
    var out = try lc.Matrix.init(2, 2);
    try lc.scale(&a, 2.0, &out);
    assert(out.at(0, 0) == 2);
    assert(out.at(1, 1) == 8);
    print("lattice: scale 2x2 green — o00={d} o11={d}\n", .{ out.at(0, 0), out.at(1, 1) });
}

fn welcome_transpose() !void {
    var a = try lc.Matrix.init(2, 3);
    a.set(0, 0, 1);
    a.set(0, 1, 2);
    a.set(0, 2, 3);
    a.set(1, 0, 4);
    a.set(1, 1, 5);
    a.set(1, 2, 6);
    var out = try lc.Matrix.init(3, 2);
    try lc.transpose(&a, &out);
    assert(out.at(0, 0) == 1);
    assert(out.at(0, 1) == 4);
    assert(out.at(1, 0) == 2);
    assert(out.at(1, 1) == 5);
    assert(out.at(2, 0) == 3);
    assert(out.at(2, 1) == 6);
    print("lattice: transpose 2x3→3x2 green — o00={d} o21={d}\n", .{ out.at(0, 0), out.at(2, 1) });
}

fn welcome_mul() !void {
    var a = try lc.Matrix.init(2, 2);
    a.set(0, 0, 2);
    a.set(0, 1, 3);
    a.set(1, 0, 4);
    a.set(1, 1, 5);
    var b = try lc.Matrix.init(2, 2);
    b.set(0, 0, 10);
    b.set(0, 1, 2);
    b.set(1, 0, 3);
    b.set(1, 1, 4);
    var out = try lc.Matrix.init(2, 2);
    try lc.mul(&a, &b, &out);
    assert(out.at(0, 0) == 20);
    assert(out.at(0, 1) == 6);
    assert(out.at(1, 0) == 12);
    assert(out.at(1, 1) == 20);
    print("lattice: mul 2x2 green — o00={d} o11={d}\n", .{ out.at(0, 0), out.at(1, 1) });
}

fn welcome_fill() !void {
    var out = try lc.Matrix.init(2, 2);
    lc.fill(&out, 7.0);
    assert(out.at(0, 0) == 7);
    assert(out.at(0, 1) == 7);
    assert(out.at(1, 0) == 7);
    assert(out.at(1, 1) == 7);
    print("lattice: fill 2x2 green — o00={d} o11={d}\n", .{ out.at(0, 0), out.at(1, 1) });
}

fn welcome_copy() !void {
    var src = try lc.Matrix.init(2, 2);
    src.set(0, 0, 1);
    src.set(0, 1, 2);
    src.set(1, 0, 3);
    src.set(1, 1, 4);
    var out = try lc.Matrix.init(2, 2);
    try lc.copy(&src, &out);
    assert(out.at(0, 0) == 1);
    assert(out.at(0, 1) == 2);
    assert(out.at(1, 0) == 3);
    assert(out.at(1, 1) == 4);
    print("lattice: copy 2x2 green — o00={d} o11={d}\n", .{ out.at(0, 0), out.at(1, 1) });
}

fn welcome_sub() !void {
    var a = try lc.Matrix.init(2, 2);
    a.set(0, 0, 10);
    a.set(0, 1, 20);
    a.set(1, 0, 30);
    a.set(1, 1, 40);
    var b = try lc.Matrix.init(2, 2);
    b.set(0, 0, 1);
    b.set(0, 1, 2);
    b.set(1, 0, 3);
    b.set(1, 1, 4);
    var out = try lc.Matrix.init(2, 2);
    try lc.sub(&a, &b, &out);
    assert(out.at(0, 0) == 9);
    assert(out.at(0, 1) == 18);
    assert(out.at(1, 0) == 27);
    assert(out.at(1, 1) == 36);
    print("lattice: sub 2x2 green — o00={d} o11={d}\n", .{ out.at(0, 0), out.at(1, 1) });
}

fn welcome_neg() !void {
    var src = try lc.Matrix.init(2, 2);
    src.set(0, 0, 1);
    src.set(0, 1, -2);
    src.set(1, 0, 3);
    src.set(1, 1, -4);
    var out = try lc.Matrix.init(2, 2);
    try lc.neg(&src, &out);
    assert(out.at(0, 0) == -1);
    assert(out.at(0, 1) == 2);
    assert(out.at(1, 0) == -3);
    assert(out.at(1, 1) == 4);
    print("lattice: neg 2x2 green — o00={d} o11={d}\n", .{ out.at(0, 0), out.at(1, 1) });
}

fn welcome_div() !void {
    var a = try lc.Matrix.init(2, 2);
    a.set(0, 0, 6);
    a.set(0, 1, 8);
    a.set(1, 0, 9);
    a.set(1, 1, 16);
    var b = try lc.Matrix.init(2, 2);
    b.set(0, 0, 2);
    b.set(0, 1, 4);
    b.set(1, 0, 3);
    b.set(1, 1, 4);
    var out = try lc.Matrix.init(2, 2);
    try lc.div(&a, &b, &out);
    assert(out.at(0, 0) == 3);
    assert(out.at(0, 1) == 2);
    assert(out.at(1, 0) == 3);
    assert(out.at(1, 1) == 4);
    print("lattice: div 2x2 green — o00={d} o11={d}\n", .{ out.at(0, 0), out.at(1, 1) });
}

fn welcome_abs() !void {
    var src = try lc.Matrix.init(2, 2);
    src.set(0, 0, -3);
    src.set(0, 1, 4);
    src.set(1, 0, -5);
    src.set(1, 1, 0);
    var out = try lc.Matrix.init(2, 2);
    try lc.abs(&src, &out);
    assert(out.at(0, 0) == 3);
    assert(out.at(0, 1) == 4);
    assert(out.at(1, 0) == 5);
    assert(out.at(1, 1) == 0);
    print("lattice: abs 2x2 green — o00={d} o10={d}\n", .{ out.at(0, 0), out.at(1, 0) });
}

fn welcome_clamp() !void {
    var src = try lc.Matrix.init(2, 2);
    src.set(0, 0, -3);
    src.set(0, 1, 4);
    src.set(1, 0, -5);
    src.set(1, 1, 0);
    var out = try lc.Matrix.init(2, 2);
    try lc.clamp(&src, 0.0, 4.0, &out);
    assert(out.at(0, 0) == 0);
    assert(out.at(0, 1) == 4);
    assert(out.at(1, 0) == 0);
    assert(out.at(1, 1) == 0);
    print("lattice: clamp 2x2 green — o00={d} o01={d}\n", .{ out.at(0, 0), out.at(0, 1) });
}

fn welcome_reduce_max() !void {
    var a = try lc.Matrix.init(2, 2);
    a.set(0, 0, -3);
    a.set(0, 1, 4);
    a.set(1, 0, -5);
    a.set(1, 1, 0);
    var out = try lc.Matrix.init(1, 1);
    try lc.reduce_max(&a, &out);
    assert(out.at(0, 0) == 4);
    print("lattice: reduce_max 2x2 green — max={d}\n", .{out.at(0, 0)});
}

