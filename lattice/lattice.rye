fn unwelcome_div_zero() !void {
    var a = try lc.Matrix.init(2, 2);
    a.set(0, 0, 1);
    a.set(0, 1, 2);
    a.set(1, 0, 3);
    a.set(1, 1, 4);
    var b = try lc.Matrix.init(2, 2);
    b.set(0, 0, 1);
    b.set(0, 1, 0);
    b.set(1, 0, 1);
    b.set(1, 1, 1);
    var out = try lc.Matrix.init(2, 2);
    if (lc.div(&a, &b, &out)) |_| {
        return error.UnwelcomePassed;
    } else |err| {
        assert(err == error.DivideByZero);
    }
    print("lattice: div by zero refused\n", .{});
}

