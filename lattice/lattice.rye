fn welcome_sqrt() !void {
    var src = try lc.Matrix.init(2, 2);
    src.set(0, 0, 4);
    src.set(0, 1, 9);
    src.set(1, 0, 0);
    src.set(1, 1, 16);
    var out = try lc.Matrix.init(2, 2);
    try lc.sqrt(&src, &out);
    assert(out.at(0, 0) == 2);
    assert(out.at(0, 1) == 3);
    assert(out.at(1, 0) == 0);
    assert(out.at(1, 1) == 4);
    print("lattice: sqrt 2x2 green — o00={d} o01={d}\n", .{ out.at(0, 0), out.at(0, 1) });
}

fn welcome_exp() !void {
    var src = try lc.Matrix.init(2, 2);
    src.set(0, 0, 0);
    src.set(0, 1, 0);
    src.set(1, 0, 0);
    src.set(1, 1, 0);
    var out = try lc.Matrix.init(2, 2);
    try lc.exp(&src, &out);
    assert(out.at(0, 0) == 1);
    assert(out.at(0, 1) == 1);
    assert(out.at(1, 0) == 1);
    assert(out.at(1, 1) == 1);
    print("lattice: exp 2x2 green — o00={d}\n", .{out.at(0, 0)});
}

fn welcome_log() !void {
    var src = try lc.Matrix.init(2, 2);
    src.set(0, 0, 1);
    src.set(0, 1, 1);
    src.set(1, 0, 1);
    src.set(1, 1, 1);
    var out = try lc.Matrix.init(2, 2);
    try lc.log(&src, &out);
    assert(out.at(0, 0) == 0);
    assert(out.at(0, 1) == 0);
    assert(out.at(1, 0) == 0);
    assert(out.at(1, 1) == 0);
    print("lattice: log 2x2 green — o00={d}\n", .{out.at(0, 0)});
}

fn unwelcome_copy_shape() !void {
    var src = try lc.Matrix.init(2, 2);
    var out = try lc.Matrix.init(2, 1);
    if (lc.copy(&src, &out)) |_| {
        return error.UnwelcomePassed;
    } else |err| {
        assert(err == error.ShapeMismatch);
    }
    print("lattice: copy shape mismatch refused\n", .{});
}

fn unwelcome_sub_shape() !void {
    var a = try lc.Matrix.init(2, 2);
    var b = try lc.Matrix.init(2, 1);
    var out = try lc.Matrix.init(2, 2);
    if (lc.sub(&a, &b, &out)) |_| {
