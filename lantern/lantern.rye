fn unwelcome_zero_budget() !void {
    const req = lc.Request{
        .model_hash = "sha3-256-rye-forge-lap0",
        .prompt = "x",
        .max_tokens = 0,
    };
    if (lc.validate_request(req)) |_| {
        return error.UnwelcomePassed;
    } else |err| {
        assert(err == error.BudgetExceeded);
    }
    print("lantern: zero budget refused\n", .{});
}

pub fn main(init: std.process.Init) !u8 {
    const garden = init.arena.allocator();
    const io = init.io;
    const args = try init.minimal.args.toSlice(garden);
    if (args.len >= 2 and std.mem.eql(u8, args[1], "selftest")) {
        try welcome_complete(io);
        try welcome_length_budget(io);
        try welcome_allowlist(io);
        try welcome_seed_temperature(io);
        try welcome_top_p(io);
        try welcome_err_stop(io);
        try welcome_stop_sequence(io);
        try welcome_prompt_pin(io);
        try welcome_max_tokens_pin(io);
        try unwelcome_model_mismatch(io);
        try unwelcome_prompt_too_long();
        try unwelcome_zero_budget();
        try unwelcome_allowlist_refuse(io);
        try unwelcome_bad_temperature();
        try unwelcome_seed_mismatch(io);
        try unwelcome_bad_top_p();
        try unwelcome_top_p_mismatch(io);
        try unwelcome_stop_sequence_mismatch(io);
        try unwelcome_bad_stop_sequence();
        try unwelcome_prompt_mismatch(io);
        try unwelcome_max_tokens_mismatch(io);
        print("lantern lap9: version {s} — GREEN\n", .{lantern_version});
        return 0;
    }
    print("usage: lantern selftest\n", .{});
    return 1;
}
