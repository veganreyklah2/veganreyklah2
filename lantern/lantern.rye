fn unwelcome_bad_stop_sequence() !void {
    const long = "abcdefghijklmnopqrstuvwxyz012345"; // 32 chars ok; 33 refused
    const too_long = long ++ "x";
    const req = lc.Request{
        .model_hash = "sha3-256-rye-forge-lap0",
        .prompt = "x",
        .max_tokens = 8,
        .stop_sequence = too_long,
    };
    if (lc.validate_request(req)) |_| {
        return error.UnwelcomePassed;
    } else |err| {
        assert(err == error.BadStopSequence);
    }
    print("lantern: bad stop_sequence refused\n", .{});
}

