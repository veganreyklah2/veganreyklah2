/// Granary weave view — resolve person/weave, fold-clone resin, Scribble → Skate.
fn compose_granary_view_lines(garden: std.mem.Allocator, io: std.Io) ![]surface.SkateLine {
    const cwd = std.Io.Dir.cwd();
    var md_buf: [granary.max_resin_bytes]u8 = undefined;
    const markdown = try cwd.readFile(io, granary_front_page_fixture, &md_buf);

    var store = granary.ResinStore.empty();
    const digest = try granary.put_resin(&store, markdown);
    var fact_buf: [granary.max_fact_len]u8 = undefined;
    const fact_len = try granary.sign_name_fact(
        granary.granary_version,
        "rio",
        "greeting",
        &digest,
        &fact_buf,
    );
    var reg = granary.Registry.empty();
    try granary.append_fact(&reg, fact_buf[0..fact_len]);
    const resolved = try granary.resolve(&reg, "rio/greeting");
    assert(std.mem.eql(u8, resolved.resin_digest, &digest));

    var clone: [granary.max_resin_bytes]u8 = undefined;
    const clone_len = try granary.clone_resin(&store, resolved.resin_digest, &clone);
    assert(std.mem.eql(u8, clone[0..clone_len], markdown));

    var frame: granary.Frame = .{};
    try granary.render_front_page(clone[0..clone_len], &frame);
    // Frame: border, heading, paragraph, rye fence, border — need middle three.
    assert(frame.line_count >= 5);
    const heading = frame.lines[1].slice();
    const paragraph = frame.lines[2].slice();
    const fence = frame.lines[3].slice();

    const lines = try garden.alloc(surface.SkateLine, granary_view_max_lines);
    lines[0] = .{ .text = try garden.dupe(u8, "granary weave view") };
    lines[1] = .{ .text = try garden.dupe(u8, "path rio/greeting") };
    lines[2] = .{ .text = try std.fmt.allocPrint(garden, "resin {s}", .{digest[0..12]}) };
    lines[3] = .{ .text = try garden.dupe(u8, heading) };
    lines[4] = .{ .text = try garden.dupe(u8, paragraph) };
    lines[5] = .{ .text = try garden.dupe(u8, fence) };
    lines[6] = .{ .text = try garden.dupe(u8, "fold green") };
    return lines;
}

fn run_granary_view_witness(garden: std.mem.Allocator, io: std.Io) !u8 {
    const empty = try garden.alloc(surface.SkateLine, 1);
    empty[0] = .{ .text = "" };
    const sig_empty = try surface.content_signature(garden, empty);

    const frame = try compose_granary_view_lines(garden, io);
    defer {
        var i: u32 = 0;
        while (i < frame.len) : (i += 1) garden.free(frame[i].text);
        garden.free(frame);
    }
    assert(frame.len == granary_view_max_lines);
    const sig = try surface.content_signature(garden, frame);
    assert(sig != sig_empty);

    const golden = [_][]const u8{
        "granary weave view",
        "path rio/greeting",
        "resin 5b3b4e968679",
        "# rio/greeting",
        "A first weave in the Granary — signed, named, and shared.",
        "[rye fence]",
        "fold green",
    };
    assert(lines_equal(&golden, frame));

    // Unwelcome — missing fixture path refuses.
    const cwd = std.Io.Dir.cwd();
    var probe: [8]u8 = undefined;
    if (cwd.readFile(io, "tools/fixtures/does_not_exist_granary_view.md", &probe)) |_| {
        return error.UnwelcomePassed;
    } else |_| {}

    var out: [160]u8 = undefined;
    const msg = try std.fmt.bufPrint(
        &out,
        "drawn terminal granary weave view: sig={x} lines={d} — GREEN\n",
        .{ sig, frame.len },
    );
    try std.Io.File.stdout().writeStreamingAll(io, msg);
    return 0;
}

/// Mandi floor view — signed vessel listing priced in MALA → Skate.
fn compose_mandi_floor_view_lines(garden: std.mem.Allocator) ![]surface.SkateLine {
    var parent: [mandi.digest_hex_len]u8 = undefined;
    mandi.witness_vessel_parent(&parent);

    var listing: [mandi.max_listing_len]u8 = undefined;
    const n = try mandi.sign_listing(mandi.mandi_version, &parent, "25", &listing);
    try mandi.verify_listing(listing[0..n]);
    try mandi.verify_against_parent(listing[0..n], &parent);

    var receipt: [mandi.digest_hex_len]u8 = undefined;
    try mandi.receipt_digest(listing[0..n], &receipt);

    const lines = try garden.alloc(surface.SkateLine, mandi_view_max_lines);
    lines[0] = .{ .text = try garden.dupe(u8, "mandi floor view") };
    lines[1] = .{ .text = try std.fmt.allocPrint(garden, "vessel {s}", .{parent[0..12]}) };
    lines[2] = .{ .text = try garden.dupe(u8, "price 25 mala") };
    lines[3] = .{ .text = try std.fmt.allocPrint(garden, "receipt {s}", .{receipt[0..12]}) };
    lines[4] = .{ .text = try garden.dupe(u8, "fold green") };
    return lines;
}

fn run_mandi_floor_view_witness(garden: std.mem.Allocator, io: std.Io) !u8 {
    const empty = try garden.alloc(surface.SkateLine, 1);
    empty[0] = .{ .text = "" };
    const sig_empty = try surface.content_signature(garden, empty);

    const frame = try compose_mandi_floor_view_lines(garden);
    defer {
        var i: u32 = 0;
        while (i < frame.len) : (i += 1) garden.free(frame[i].text);
        garden.free(frame);
    }
    assert(frame.len == mandi_view_max_lines);
    const sig = try surface.content_signature(garden, frame);
    assert(sig != sig_empty);

    const golden = [_][]const u8{
        "mandi floor view",
        "vessel 675cd344edbf",
        "price 25 mala",
        "receipt a8e89899c996",
        "fold green",
    };
    assert(lines_equal(&golden, frame));

    // Unwelcome — lying stamp_sig refused.
    var parent: [mandi.digest_hex_len]u8 = undefined;
    mandi.witness_vessel_parent(&parent);
    var lying: [mandi.max_listing_len]u8 = undefined;
    const ln = try mandi.sign_listing(mandi.mandi_version, &parent, "10", &lying);
    const sig_key = "stamp_sig ";
    const sig_at = std.mem.indexOf(u8, lying[0..ln], sig_key) orelse return error.MissingSig;
    lying[sig_at + sig_key.len] = if (lying[sig_at + sig_key.len] == '0') '1' else '0';
    if (mandi.verify_listing(lying[0..ln])) |_| {
        return error.LyingAccepted;
    } else |err| {
        assert(err == error.VerifyFailed);
    }

    var out: [160]u8 = undefined;
    const msg = try std.fmt.bufPrint(
        &out,
        "drawn terminal mandi floor view: sig={x} lines={d} — GREEN\n",
        .{ sig, frame.len },
    );
    try std.Io.File.stdout().writeStreamingAll(io, msg);
    return 0;
}

fn run_session_witness(garden: std.mem.Allocator, io: std.Io, init: std.process.Init) !u8 {
    var env = rishi.Env{};
    var history = rishi.History{};
    var transcript = rishi.Transcript{};
    var store_ready = false;

    const script = [_][]const u8{ "let ring3 = 1", "let ring3b = 2", ":recall 1" };
    var sig_1: u64 = 0;
    var sig_2: u64 = 0;
    var sig_final: u64 = 0;

    for (script, 0..) |line, idx| {
        _ = try rishi.run_one_input(garden, io, init, &env, &history, &transcript, &store_ready, line);
        const frame_lines = try compose_frame_lines(garden, &transcript, "");
        defer garden.free(frame_lines);
        const sig = try surface.content_signature(garden, frame_lines);
        if (idx == 0) sig_1 = sig;
        if (idx == 1) sig_2 = sig;
        sig_final = sig;
    }

    assert(sig_1 != sig_2);

    const golden = [_][]const u8{
        "rishi> let ring3 = 1",
        "rishi> let ring3b = 2",
        "rishi> :recall 1",
        "rishi> let ring3 = 1",
        "",
        "",
    };
    const final_lines = try compose_frame_lines(garden, &transcript, "");
    defer garden.free(final_lines);
    assert(lines_equal(&golden, final_lines));
    const sig_golden = try surface.content_signature(garden, final_lines);
    assert(sig_final == sig_golden);

    const pre_full_lines = try compose_frame_lines(garden, &transcript, "");
    defer garden.free(pre_full_lines);
    const sig_pre_full = try surface.content_signature(garden, pre_full_lines);

    var fill: u32 = 0;
    var pad_buf: [fill_say_width + 16]u8 = undefined;
    @memset(pad_buf[0..fill_say_width], 'p');
    const pad_payload = pad_buf[0..fill_say_width];
    while (!transcript.full and fill < fill_line_count) : (fill += 1) {
        var line_buf: [fill_say_width + 32]u8 = undefined;
        const pad_line = try std.fmt.bufPrint(&line_buf, "say \"{s}\"", .{pad_payload});
        _ = try rishi.run_one_input(garden, io, init, &env, &history, &transcript, &store_ready, pad_line);
    }
    assert(transcript.full);

    const full_lines = try compose_frame_lines(garden, &transcript, status_full_text);
    defer garden.free(full_lines);
    const sig_full = try surface.content_signature(garden, full_lines);
    assert(sig_full != sig_pre_full);
    assert(std.mem.eql(u8, full_lines[full_lines.len - 1].text, status_full_text));

    var out: [160]u8 = undefined;
    const msg = try std.fmt.bufPrint(
        &out,
        "drawn terminal session witness: sig_1={x} sig_2={x} sig_final={x} ceiling={x} — GREEN\n",
        .{ sig_1, sig_2, sig_final, sig_full },
    );
    try std.Io.File.stdout().writeStreamingAll(io, msg);
    return 0;
}

fn run_rw2_collaboration_witness(garden: std.mem.Allocator, io: std.Io, init: std.process.Init) !u8 {
    var env = rishi.Env{};
    var history = rishi.History{};
    var transcript = rishi.Transcript{};
    var store_ready = false;

    const boot = try garden.alloc(surface.SkateLine, 1);
    boot[0] = .{ .text = "rw2 boot" };
    const sig_boot = try surface.content_signature(garden, boot);

    _ = try rishi.run_one_input(garden, io, init, &env, &history, &transcript, &store_ready, "let rw2 = 1");
    const frame_one = try compose_frame_lines(garden, &transcript, "");
    defer garden.free(frame_one);
    const sig_one = try surface.content_signature(garden, frame_one);
    assert(sig_boot != sig_one);

    const sig_one_again = try surface.content_signature(garden, frame_one);
    assert(sig_one_again == sig_one);

    const empty_transcript = rishi.Transcript{};
    const empty_lines = try compose_frame_lines(garden, &empty_transcript, "");
    defer garden.free(empty_lines);
    const sig_empty = try surface.content_signature(garden, empty_lines);
    const sig_empty_again = try surface.content_signature(garden, empty_lines);
    assert(sig_empty == sig_empty_again);

    const sig_before_bad = try surface.content_signature(garden, frame_one);
    const bad_result = try rishi.run_one_input(garden, io, init, &env, &history, &transcript, &store_ready, ":recall 99");
    assert(bad_result == .advance);
    const frame_after_bad = try compose_frame_lines(garden, &transcript, "");
    defer garden.free(frame_after_bad);
    _ = try surface.content_signature(garden, frame_after_bad);
    assert(sig_before_bad != sig_boot);

    var out: [128]u8 = undefined;
    const msg = try std.fmt.bufPrint(
        &out,
        "drawn terminal rw2 collaboration: boot={x} one={x} empty={x} — GREEN\n",
        .{ sig_boot, sig_one, sig_empty },
    );
    try std.Io.File.stdout().writeStreamingAll(io, msg);
    return 0;
}

fn run_keyboard_witness(garden: std.mem.Allocator, io: std.Io, init: std.process.Init) !u8 {
    var env = rishi.Env{};
    var history = rishi.History{};
    var transcript = rishi.Transcript{};
    var store_ready = false;
    var editor = window_input.LineEditor{};

    feed_line_through_editor(&editor, "let kb = 1");
    const first_line = (try editor.take_submitted_line(garden)) orelse return 1;
    _ = try rishi.run_one_input(garden, io, init, &env, &history, &transcript, &store_ready, first_line);

    const mid_lines = try compose_frame_lines(garden, &transcript, "");
    defer garden.free(mid_lines);
    const sig_mid = try surface.content_signature(garden, mid_lines);
    assert(std.mem.indexOf(u8, mid_lines[0].text, "let kb = 1") != null);

    var typing_editor = window_input.LineEditor{};
    typing_editor.push_char('a');
    const typing_status = try format_prompt_status(garden, &typing_editor, false);
    const typing_lines = try compose_frame_lines(garden, &transcript, typing_status);
    defer garden.free(typing_lines);
    const sig_typing = try surface.content_signature(garden, typing_lines);
    assert(sig_typing != sig_mid);
    assert(std.mem.eql(u8, typing_lines[typing_lines.len - 1].text, "rishi> a"));

    feed_line_through_editor(&editor, ":quit");
    const quit_line = (try editor.take_submitted_line(garden)) orelse return 1;
    const signal = try rishi.run_one_input(garden, io, init, &env, &history, &transcript, &store_ready, quit_line);
    assert(signal == .quit);

    var out: [128]u8 = undefined;
    const msg = try std.fmt.bufPrint(
        &out,
        "drawn terminal keyboard witness: sig_mid={x} sig_typing={x} — GREEN\n",
        .{ sig_mid, sig_typing },
    );
    try std.Io.File.stdout().writeStreamingAll(io, msg);
    return 0;
}

fn poll_stdin_and_display(app: *surface.SurfaceApp, stdin_fd: posix.fd_t) !enum { stdin_ready, display_ready, timeout } {
    const display_fd = app.display_fd();
    var fds = [_]posix.pollfd{
        .{ .fd = display_fd, .events = posix.POLL.IN, .revents = 0 },
        .{ .fd = stdin_fd, .events = posix.POLL.IN, .revents = 0 },
    };
    const ready = posix.poll(&fds, poll_timeout_ms) catch 0;
    if (ready == 0) return .timeout;
    if ((fds[1].revents & posix.POLL.IN) != 0) return .stdin_ready;
    if ((fds[0].revents & posix.POLL.IN) != 0) return .display_ready;
    return .timeout;
}

fn redraw_prompt_frame(
    garden: std.mem.Allocator,
    app: *surface.SurfaceApp,
    transcript: *const rishi.Transcript,
    editor: *const window_input.LineEditor,
) !void {
    const status = try format_prompt_status(garden, editor, transcript.full);
    const frame_lines = try compose_frame_lines(garden, transcript, status);
    defer garden.free(frame_lines);
    try app.update_frame(frame_lines);
}

fn run_submitted_line(
    garden: std.mem.Allocator,
    io: std.Io,
    init: std.process.Init,
    app: *surface.SurfaceApp,
    env: *rishi.Env,
    history: *rishi.History,
    transcript: *rishi.Transcript,
    store_ready: *bool,
    line: []const u8,
) !?rishi.StepSignal {
    const signal = try rishi.run_one_input(garden, io, init, env, history, transcript, store_ready, line);
    const status = if (transcript.full) status_full_text else "";
    const frame_lines = try compose_frame_lines(garden, transcript, status);
    defer garden.free(frame_lines);
    try app.update_frame(frame_lines);
    if (signal == .quit) return signal;
    return signal;
}

fn live_boot_app(garden: std.mem.Allocator, io: std.Io) !struct { app: surface.SurfaceApp, editor: window_input.LineEditor } {
    const editor = window_input.LineEditor{};
    const boot_lines = try garden.alloc(surface.SkateLine, 1);
    boot_lines[0] = .{ .text = "drawn terminal — type in the window; stdin still works for dev" };

    var app = try surface.open_surface(garden, boot_lines);
    app.enable_keyboard();
    try app.prepare_surface();
    app.set_window_title("drawn terminal");
    app.set_app_id("drawn-terminal");
    try app.set_frame(boot_lines);

    try std.Io.File.stdout().writeStreamingAll(io, "drawn terminal live — keyboard focus in the window; stdin still works.\n");
    return .{ .app = app, .editor = editor };
}

fn live_drain_keyboard(
    garden: std.mem.Allocator,
    io: std.Io,
    init: std.process.Init,
    app: *surface.SurfaceApp,
    env: *rishi.Env,
    history: *rishi.History,
    transcript: *rishi.Transcript,
    store_ready: *bool,
    editor: *window_input.LineEditor,
) !?u8 {
    while (app.has_key_action()) {
        const key_action = app.pop_key_action();
        if (surface_action_to_editor(key_action)) |editor_action| {
            editor.apply_action(editor_action);
            if (editor_action == .submit) {
                if (try editor.take_submitted_line(garden)) |line| {
                    if (try run_submitted_line(garden, io, init, app, env, history, transcript, store_ready, line)) |_| {
                        return 0;
                    }
                }
            } else {
                try redraw_prompt_frame(garden, app, transcript, editor);
            }
        }
    }
    return null;
}

fn live_read_stdin_submit(
    garden: std.mem.Allocator,
    io: std.Io,
    init: std.process.Init,
    app: *surface.SurfaceApp,
    env: *rishi.Env,
    history: *rishi.History,
    transcript: *rishi.Transcript,
    store_ready: *bool,
    reader: *std.Io.Reader,
    stdout: std.Io.File,
) !?u8 {
    try stdout.writeStreamingAll(io, "rishi> ");
    const raw_line = reader.takeDelimiterInclusive('\n') catch |err| switch (err) {
        error.EndOfStream => return 0,
        else => return 1,
    };
    const line = std.mem.trim(u8, raw_line, " \t\r\n");
    if (line.len == 0) return null;
    if (try run_submitted_line(garden, io, init, app, env, history, transcript, store_ready, line)) |_| {
        return 0;
    }
    return null;
}

fn run_live(garden: std.mem.Allocator, io: std.Io, init: std.process.Init) !u8 {
    var env = rishi.Env{};
    var history = rishi.History{};
    var transcript = rishi.Transcript{};
    var store_ready = false;

    var live = try live_boot_app(garden, io);
    defer live.app.disconnect();

    const stdout = std.Io.File.stdout();
    const stdin_fd: posix.fd_t = posix.STDIN_FILENO;
    var stdin_buffer: [4096]u8 = undefined;
    var file_reader = std.Io.File.Reader.initStreaming(std.Io.File.stdin(), io, &stdin_buffer);
    const reader = &file_reader.interface;

    while (true) {
        if (live.app.wants_close()) return 0;
        const ready = try poll_stdin_and_display(&live.app, stdin_fd);
        try live.app.dispatch_once(live_dispatch_ms);
        switch (ready) {
            .display_ready, .timeout => {
                if (try live_drain_keyboard(garden, io, init, &live.app, &env, &history, &transcript, &store_ready, &live.editor)) |code| {
                    return code;
                }
            },
            .stdin_ready => {
                if (try live_read_stdin_submit(garden, io, init, &live.app, &env, &history, &transcript, &store_ready, reader, stdout)) |code| {
                    return code;
                }
            },
        }
    }
}

fn run_metal_smoke(garden: std.mem.Allocator, io: std.Io, init: std.process.Init) !u8 {
    var env = rishi.Env{};
    var history = rishi.History{};
    var transcript = rishi.Transcript{};
    var store_ready = false;

    _ = try rishi.run_one_input(garden, io, init, &env, &history, &transcript, &store_ready, "let smoke = 1");
    _ = try rishi.run_one_input(garden, io, init, &env, &history, &transcript, &store_ready, "say \"metal\"");

    const frame_lines = try compose_frame_lines(garden, &transcript, "");
    defer garden.free(frame_lines);

    var app = try surface.open_surface(garden, frame_lines);
    defer app.disconnect();
    try app.prepare_surface();
    try app.set_frame(frame_lines);

    var beat: u32 = 0;
    while (beat < 8) : (beat += 1) {
        try app.dispatch_once(50);
    }

    try std.Io.File.stdout().writeStreamingAll(io, "drawn terminal metalsmoke: session mirrored on Wayland — GREEN\n");
    return 0;
}

pub fn main(init: std.process.Init) !u8 {
    const garden = init.arena.allocator();
    const io = init.io;
    const args = try init.minimal.args.toSlice(garden);
    if (args.len >= 2 and std.mem.eql(u8, args[1], "sessiontest")) {
        return run_session_witness(garden, io, init);
    }
    if (args.len >= 2 and std.mem.eql(u8, args[1], "rw2collabtest")) {
        return run_rw2_collaboration_witness(garden, io, init);
    }
    if (args.len >= 2 and std.mem.eql(u8, args[1], "thinviewtest")) {
        return run_thin_view_witness(garden, io);
    }
    if (args.len >= 2 and std.mem.eql(u8, args[1], "booksviewtest")) {
        return run_books_view_witness(garden, io);
    }
    if (args.len >= 2 and std.mem.eql(u8, args[1], "sightviewtest")) {
        return run_sight_view_witness(garden, io);
    }
    if (args.len >= 2 and std.mem.eql(u8, args[1], "assistviewtest")) {
        return run_assist_view_witness(garden, io);
    }
    if (args.len >= 2 and std.mem.eql(u8, args[1], "queryviewtest")) {
        return run_query_view_witness(garden, io);
    }
    if (args.len >= 2 and std.mem.eql(u8, args[1], "forgeviewtest")) {
        return run_forge_view_witness(garden, io);
    }
    if (args.len >= 2 and std.mem.eql(u8, args[1], "forgequeryviewtest")) {
        return run_forge_query_view_witness(garden, io);
    }
    if (args.len >= 2 and std.mem.eql(u8, args[1], "granaryviewtest")) {
        return run_granary_view_witness(garden, io);
    }
    if (args.len >= 2 and std.mem.eql(u8, args[1], "mandiviewtest")) {
        return run_mandi_floor_view_witness(garden, io);
    }
    if (args.len >= 2 and std.mem.eql(u8, args[1], "keyboardtest")) {
        return run_keyboard_witness(garden, io, init);
    }
    if (args.len >= 2 and std.mem.eql(u8, args[1], "metalsmoke")) {
        return run_metal_smoke(garden, io, init);
    }
    return run_live(garden, io, init);
}
