# chain_read_monad.rish — Monad testnet read host (delegates to POSIX seam).
#
# Run from the repository root:
#   rishi/bin/rishi run tools/chain_read_monad.rish <tx_hash> [rpc_url]
#
# Orchestration host; external interpreter work stays in comlink/chain_read_monad.sh.

let forwarded = join args " "
let result = run ["sh" "-c" "comlink/chain_read_monad.sh ${forwarded}"]
say result.out
exit result.code
