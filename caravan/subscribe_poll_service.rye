//! caravan/subscribe_poll_service.rye — production scheduling: supervise poll wire work.
//!
//! Ring C supervises Mantra's subscribe-poll delivery with the exit-code convention
//! from `supervisor_exit.rye`: **cycle_ok** (0) spawns again; **stop_requested** (8)
//! halts; any other non-zero is a fall and restarts. A long-lived source child
//! answers catch-up requests; each fetcher-poll worker runs one wire cycle and
//! checks the stop sentinel at the boundary. SIGTERM/SIGINT flip an atomic flag;
//! the loop top creates the same sentinel the witness hook and a manual `touch` use.
//!
//!   rye build caravan/subscribe_poll_service.rye -lc -femit-bin=caravan/bin/subscribe-poll-service
//!   caravan/bin/subscribe-poll-service <delivery-binary> <stop-sentinel-path> [witness-stop-after-N]
//!
//! Counsel: [`external-research/20260707-004712`](../external-research/20260707-004712_claude-counsel-outer-subscribe-and-host-mirror.md)
//! · [`external-research/20260707-014212_claude-counsel-graceful-stop-reframed.md`](../external-research/20260707-014212_claude-counsel-graceful-stop-reframed.md)
//! · [`external-research/20260707-021012_claude-counsel-ring4-signal-handler.md`](../external-research/20260707-021012_claude-counsel-ring4-signal-handler.md)

const std = @import("std");
const assert = std.debug.assert;
const print = std.debug.print;
const c = std.c;
const se = @import("supervisor_exit.rye");
const ss = @import("supervisor_signal.rye");

const caravan_subscribe_poll_service_version = "20260707.021012";

const max_fall_restarts: u32 = 5;
const source_ready_ns: u64 = 50_000_000;

pub fn main(init: std.process.Init) !u8 {
    const io = init.io;
    const garden = init.arena.allocator();
    const args = try init.minimal.args.toSlice(garden);

    if (args.len < 3) {
        print("usage: subscribe-poll-service <delivery-binary> <stop-sentinel-path> [witness-stop-after-N]\n", .{});
        return 1;
    }

    const witness_stop_after: ?u32 = if (args.len >= 4)
        try std.fmt.parseInt(u32, args[3], 10)
    else
        null;

    return runSupervisor(garden, io, args[1], args[2], witness_stop_after);
}

fn createStopSentinel(io: std.Io, sentinel_path: []const u8) !void {
    const f = try std.Io.Dir.cwd().createFile(io, sentinel_path, .{});
    f.close(io);
}

fn runSupervisor(
    allocator: std.mem.Allocator,
    io: std.Io,
    delivery_path: []const u8,
    sentinel_path: []const u8,
    witness_stop_after: ?u32,
) !u8 {
    ss.installHandlers();

    print("caravan poll-service: supervisor alive. delivery {s} sentinel {s}\n", .{
        delivery_path, sentinel_path,
    });

    std.Io.Dir.cwd().deleteFile(io, sentinel_path) catch {};

    const source_argv = try allocator.alloc([]const u8, 2);
    source_argv[0] = delivery_path;
    source_argv[1] = "source-loop";

    var source_child = try std.process.spawn(io, .{ .argv = source_argv });
    var pause = c.timespec{ .sec = 0, .nsec = @intCast(source_ready_ns) };
    _ = c.nanosleep(&pause, null);

    var ordinary_seen: u32 = 0;
    var fall_restarts: u32 = 0;

    while (true) {
        var should_create_sentinel = ss.stopRequested();
        if (witness_stop_after) |n| {
            if (ordinary_seen == n) should_create_sentinel = true;
        }
        if (should_create_sentinel) {
            try createStopSentinel(io, sentinel_path);
        }

        const fetcher_argv = try allocator.alloc([]const u8, 3);
        fetcher_argv[0] = delivery_path;
        fetcher_argv[1] = "fetcher-poll";
        fetcher_argv[2] = sentinel_path;

        var fetcher_child = try std.process.spawn(io, .{ .argv = fetcher_argv });
        const term = try fetcher_child.wait(io);
        const code: u8 = switch (term) {
            .exited => |c0| c0,
            else => 255,
        };

        if (se.supervisorStops(code)) {
            print("caravan poll-service: stop after {d} ordinary cycle(s), {d} fall restart(s)\n", .{
                ordinary_seen, fall_restarts,
            });
            source_child.kill(io);
            break;
        }

        if (code == se.cycle_ok) {
            ordinary_seen += 1;
            continue;
        }

        if (se.supervisorRestartsAfterFall(code)) {
            fall_restarts += 1;
            print("caravan poll-service: fall restart {d}/{d}\n", .{ fall_restarts, max_fall_restarts });
            if (fall_restarts >= max_fall_restarts) {
                source_child.kill(io);
                return 1;
            }
            continue;
        }

        source_child.kill(io);
        return code;
    }

    if (witness_stop_after) |n| assert(ordinary_seen == n);

    print("caravan poll-service: supervised poll — restart on cycle_ok, stop on sentinel — GREEN.\n", .{});
    print("caravan poll-service: version {s} signal {s}\n", .{
        caravan_subscribe_poll_service_version, ss.supervisor_signal_version,
    });
    return 0;
}
