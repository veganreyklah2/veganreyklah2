//! linengrow/open_asks_lap5_delivery.rye — OA-L5: acceptance, completion, consent on Comlink wire.
//!
//!   rye build linengrow/open_asks_lap5_delivery.rye -lc -femit-bin=linengrow/bin/open-asks-lap5
//!   linengrow/bin/open-asks-lap5 selftest
//!   linengrow/bin/open-asks-lap5 demo
//!
//! Finishes the open-asks wire: request and application (OA-L2) already cross localhost;
//! this lap seals acceptance, completion (SLC-L1 payment fact), and consent the same way.

const std = @import("std");
const assert = std.debug.assert;
const print = std.debug.print;
const c = std.c;
const Dir = std.Io.Dir;
const Ed25519 = std.crypto.sign.Ed25519;
const oa = @import("open_asks.rye");
const rc = @import("receipt_core.rye");
const wf = @import("wire_format.rye");
const tally_copy = @import("tally_copy.rye");

const oa5_version = "20260707.031912";

const AF_INET: c_uint = 2;
const SOCK_DGRAM: c_uint = 2;
const SOL_SOCKET: c_int = 1;
const SO_REUSEADDR: c_int = 2;

const applicant_port: u16 = 38488;
const poster_port: u16 = 38489;

const sockaddr_in = extern struct {
    sin_family: c_ushort = AF_INET,
    sin_port: c_ushort,
    sin_addr: [4]u8 = .{ 127, 0, 0, 1 },
    sin_zero: [8]u8 = .{0} ** 8,
};

fn localhostAddr(port: u16) sockaddr_in {
    return .{
        .sin_port = std.mem.nativeToBig(u16, port),
    };
}

fn openSocket() !c.fd_t {
    const fd = c.socket(AF_INET, SOCK_DGRAM, 0);
    if (fd < 0) return error.SocketFailed;
    const yes: c_int = 1;
    _ = c.setsockopt(fd, SOL_SOCKET, SO_REUSEADDR, &yes, @sizeOf(c_int));
    return fd;
}

fn sendWire(port: u16, wire: []const u8) !void {
    const fd = try openSocket();
    defer _ = c.close(fd);
    const dest = localhostAddr(port);
    const sent = c.sendto(fd, wire.ptr, @intCast(wire.len), 0, @ptrCast(&dest), @sizeOf(sockaddr_in));
    if (sent < 0 or @as(usize, @intCast(sent)) != wire.len) return error.SendFailed;
}

fn recvWire(port: u16, wire: []u8) !u64 {
    const fd = try openSocket();
    defer _ = c.close(fd);
    var bind_addr = localhostAddr(port);
    if (c.bind(fd, @ptrCast(&bind_addr), @sizeOf(sockaddr_in)) < 0) return error.BindFailed;
    var from: sockaddr_in = undefined;
    var from_len: c.socklen_t = @sizeOf(sockaddr_in);
    const n = c.recvfrom(fd, wire.ptr, @intCast(wire.len), 0, @ptrCast(&from), &from_len);
    if (n < 0) return error.RecvFailed;
    return @intCast(n);
}

fn sealPayload(payload: []const u8, wire: *[@intCast(wf.wire_capacity)]u8) !u64 {
    return try wf.sealMessage(payload, wire);
}

fn openWire(wire: []const u8, opened: *[@intCast(wf.max_message)]u8) !u64 {
    return try wf.openDatagram(wire, opened);
}

fn pubkeyHex(kp: Ed25519.KeyPair, out: *[64]u8) void {
    const bytes = kp.public_key.toBytes();
    var i: u32 = 0;
    while (i < 32) : (i += 1) {
        _ = std.fmt.bufPrint(out[i * 2 ..][0..2], "{x:0>2}", .{bytes[i]}) catch unreachable;
    }
}

fn appendSigned(sig: Ed25519.Signature, fact: []const u8, log: []u8, log_len: *u32) error{Overflow}!void {
    var line: [oa.max_line_len]u8 = undefined;
    const line_len = try rc.formatLogLine(sig, fact, &line);
    if (log_len.* + line_len > log.len) return error.Overflow;
    tally_copy.copy_disjoint(u8, log[log_len.*..][0..line_len], line[0..line_len]);
    log_len.* += line_len;
}

fn loadSignedRequest(io: std.Io, poster_kp: Ed25519.KeyPair) !struct {
    canonical: [oa.max_oa_fact]u8,
    canonical_len: u32,
    sig: Ed25519.Signature,
    ref_hex: [oa.ref_hex_len]u8,
    stipend_buf: [16]u8,
    stipend_len: u32,
} {
    const fixture_path = "tools/fixtures/open_asks_request.bron";
    const cwd = Dir.cwd();
    var fixture_buf: [oa.max_oa_fact]u8 = undefined;
    const fixture_read = try cwd.readFile(io, fixture_path, &fixture_buf);
    assert(fixture_read.len <= oa.max_oa_fact);

    var req_fields: oa.RequestFields = undefined;
    try oa.parseRequestFields(fixture_read, &req_fields);

    var canonical: [oa.max_oa_fact]u8 = undefined;
    const canonical_len = try oa.writeCanonicalRequest(req_fields, &canonical);
    const sig = poster_kp.sign(canonical[0..canonical_len], null) catch unreachable;

    var ref_hex: [oa.ref_hex_len]u8 = undefined;
    oa.requestRefHex(canonical[0..canonical_len], &ref_hex);

    var stipend_buf: [16]u8 = undefined;
    if (req_fields.stipend.len > stipend_buf.len) return error.Overflow;
    tally_copy.copy_disjoint(u8, stipend_buf[0..req_fields.stipend.len], req_fields.stipend);

    return .{
        .canonical = canonical,
        .canonical_len = canonical_len,
        .sig = sig,
        .ref_hex = ref_hex,
        .stipend_buf = stipend_buf,
        .stipend_len = @intCast(req_fields.stipend.len),
    };
}

fn verifyRequestPayload(payload: []const u8, poster_pk: Ed25519.PublicKey, fact_out: []u8) !struct { fact_len: u32, ref_hex: [oa.ref_hex_len]u8 } {
    var sig_buf: [Ed25519.Signature.encoded_length]u8 = undefined;
    const decoded = try oa.decodeCompactPayload(payload, &sig_buf, fact_out);
    const fact = fact_out[0..decoded.fact_len];
    try rc.verifyRecord(sig_buf[0..Ed25519.Signature.encoded_length], fact, poster_pk);
    const kind = try oa.classifyFact(fact);
    if (kind != .request) return error.InvalidFact;
    var ref_hex: [oa.ref_hex_len]u8 = undefined;
    oa.requestRefHex(fact, &ref_hex);
    return .{ .fact_len = decoded.fact_len, .ref_hex = ref_hex };
}

fn verifyApplicationPayload(payload: []const u8, applicant_pk: Ed25519.PublicKey, expected_ref: []const u8, sig_out: []u8, fact_out: []u8) !u32 {
    const decoded = try oa.decodeCompactPayload(payload, sig_out, fact_out);
    const fact = fact_out[0..decoded.fact_len];
    try rc.verifyRecord(sig_out[0..Ed25519.Signature.encoded_length], fact, applicant_pk);
    const kind = try oa.classifyFact(fact);
    if (kind != .application) return error.InvalidFact;
    var fields: oa.ApplicationFields = undefined;
    try oa.parseApplicationFields(fact, &fields);
    if (!std.mem.eql(u8, fields.request_ref, expected_ref)) return error.FoldFailed;
    return decoded.fact_len;
}

fn verifyAcceptancePayload(payload: []const u8, poster_pk: Ed25519.PublicKey, expected_ref: []const u8, expected_applicant: []const u8, sig_out: []u8, fact_out: []u8) !u32 {
    const decoded = try oa.decodeCompactPayload(payload, sig_out, fact_out);
    const fact = fact_out[0..decoded.fact_len];
    try rc.verifyRecord(sig_out[0..Ed25519.Signature.encoded_length], fact, poster_pk);
    const kind = try oa.classifyFact(fact);
    if (kind != .acceptance) return error.InvalidFact;
    var fields: oa.AcceptanceFields = undefined;
    try oa.parseAcceptanceFields(fact, &fields);
    if (!std.mem.eql(u8, fields.request_ref, expected_ref)) return error.FoldFailed;
    if (!std.mem.eql(u8, fields.applicant, expected_applicant)) return error.FoldFailed;
    return decoded.fact_len;
}

fn verifyCompletionPayload(payload: []const u8, poster_pk: Ed25519.PublicKey, expected_ref: []const u8, expected_applicant: []const u8, expected_stipend: i64, sig_out: []u8, fact_out: []u8) !u32 {
    const decoded = try oa.decodeCompactPayload(payload, sig_out, fact_out);
    const fact = fact_out[0..decoded.fact_len];
    try rc.verifyRecord(sig_out[0..Ed25519.Signature.encoded_length], fact, poster_pk);
    const kind = try oa.classifyFact(fact);
    if (kind != .completion) return error.InvalidFact;
    var fields: rc.FactFields = undefined;
    try rc.parseFactFields(fact, &fields);
    if (!std.mem.eql(u8, fields.to, expected_applicant)) return error.FoldFailed;
    const amount = try rc.parseAmountSigned(fields.amount);
    if (amount != expected_stipend) return error.FoldFailed;
    var memo_buf: [128]u8 = undefined;
    const memo_written = try std.fmt.bufPrint(&memo_buf, "{s}{s}", .{ oa.completion_memo_prefix, expected_ref });
    if (!std.mem.eql(u8, fields.memo, memo_written)) return error.FoldFailed;
    return decoded.fact_len;
}

fn verifyConsentPayload(payload: []const u8, applicant_pk: Ed25519.PublicKey, expected_ref: []const u8, expected_consent: []const u8, sig_out: []u8, fact_out: []u8) !u32 {
    const decoded = try oa.decodeCompactPayload(payload, sig_out, fact_out);
    const fact = fact_out[0..decoded.fact_len];
    try rc.verifyRecord(sig_out[0..Ed25519.Signature.encoded_length], fact, applicant_pk);
    const kind = try oa.classifyFact(fact);
    if (kind != .consent) return error.InvalidFact;
    var fields: oa.ConsentFields = undefined;
    try oa.parseConsentFields(fact, &fields);
    if (!std.mem.eql(u8, fields.request_ref, expected_ref)) return error.FoldFailed;
    if (!std.mem.eql(u8, fields.consent, expected_consent)) return error.FoldFailed;
    return decoded.fact_len;
}

fn sealAndOpen(payload: []const u8, opened: *[@intCast(wf.max_message)]u8) !u64 {
    var wire: [@intCast(wf.wire_capacity)]u8 = undefined;
    const wire_len = try sealPayload(payload, &wire);
    return try openWire(wire[0..@intCast(wire_len)], opened);
}

fn buildSignedAcceptance(
    poster_kp: Ed25519.KeyPair,
    poster_hex: []const u8,
    applicant_hex: []const u8,
    ref_hex: []const u8,
) !struct { sig: Ed25519.Signature, canonical: [oa.max_oa_fact]u8, canonical_len: u32 } {
    const acc_fields = oa.AcceptanceFields{
        .poster = poster_hex,
        .request_ref = ref_hex,
        .applicant = applicant_hex,
        .stamp = "20260706.003100",
    };
    var canonical: [oa.max_oa_fact]u8 = undefined;
    const len = try oa.writeCanonicalAcceptance(acc_fields, &canonical);
    const sig = poster_kp.sign(canonical[0..len], null) catch unreachable;
    return .{ .sig = sig, .canonical = canonical, .canonical_len = len };
}

fn buildSignedCompletion(
    poster_kp: Ed25519.KeyPair,
    poster_hex: []const u8,
    applicant_hex: []const u8,
    ref_hex: []const u8,
    stipend_text: []const u8,
) !struct { sig: Ed25519.Signature, canonical: [oa.max_oa_fact]u8, canonical_len: u32 } {
    var memo_buf: [128]u8 = undefined;
    const memo_written = try std.fmt.bufPrint(&memo_buf, "{s}{s}", .{ oa.completion_memo_prefix, ref_hex });
    const completion_fields = rc.FactFields{
        .from = poster_hex,
        .to = applicant_hex,
        .amount = stipend_text,
        .memo = memo_written,
        .stamp = "20260706.003200",
    };
    var canonical: [oa.max_oa_fact]u8 = undefined;
    const len = try rc.writeCanonicalFact(completion_fields, &canonical);
    const sig = poster_kp.sign(canonical[0..len], null) catch unreachable;
    return .{ .sig = sig, .canonical = canonical, .canonical_len = len };
}

fn buildSignedConsent(
    applicant_kp: Ed25519.KeyPair,
    applicant_hex: []const u8,
    ref_hex: []const u8,
) !struct { sig: Ed25519.Signature, canonical: [oa.max_oa_fact]u8, canonical_len: u32 } {
    const consent_fields = oa.ConsentFields{
        .applicant = applicant_hex,
        .request_ref = ref_hex,
        .consent = oa.consent_grant,
        .stamp = "20260706.003300",
    };
    var canonical: [oa.max_oa_fact]u8 = undefined;
    const len = try oa.writeCanonicalConsent(consent_fields, &canonical);
    const sig = applicant_kp.sign(canonical[0..len], null) catch unreachable;
    return .{ .sig = sig, .canonical = canonical, .canonical_len = len };
}

const Oa5SelftestWire = struct {
    signed_req_sig: Ed25519.Signature,
    signed_req_canonical: [oa.max_oa_fact]u8,
    signed_req_len: u32,
    applicant_hex: [64]u8,
    wire_app_sig: Ed25519.Signature,
    app_fact: [oa.max_oa_fact]u8,
    app_fact_len: u32,
    wire_acc_sig: Ed25519.Signature,
    acc_fact: [oa.max_oa_fact]u8,
    acc_fact_len: u32,
    wire_pay_sig: Ed25519.Signature,
    pay_fact: [oa.max_oa_fact]u8,
    pay_fact_len: u32,
    wire_consent_sig: Ed25519.Signature,
    consent_fact: [oa.max_oa_fact]u8,
    consent_fact_len: u32,
};

fn selftestOa5VerifyWireLegs(
    io: std.Io,
    poster_kp: Ed25519.KeyPair,
    applicant_kp: Ed25519.KeyPair,
    poster_pk: Ed25519.PublicKey,
    applicant_pk: Ed25519.PublicKey,
) !Oa5SelftestWire {
    const signed_req = try loadSignedRequest(io, poster_kp);

    var req_payload: [oa.oa2_payload_header + oa.max_oa_fact]u8 = undefined;
    const req_payload_len = try oa.encodeCompactPayload(signed_req.sig, signed_req.canonical[0..signed_req.canonical_len], &req_payload);
    var opened: [@intCast(wf.max_message)]u8 = undefined;
    const req_opened_len = try sealAndOpen(req_payload[0..req_payload_len], &opened);
    var req_fact_buf: [oa.max_oa_fact]u8 = undefined;
    const verified_req = try verifyRequestPayload(opened[0..@intCast(req_opened_len)], poster_pk, &req_fact_buf);

    var applicant_hex: [64]u8 = undefined;
    var poster_hex: [64]u8 = undefined;
    pubkeyHex(applicant_kp, &applicant_hex);
    pubkeyHex(poster_kp, &poster_hex);

    const app_fields = oa.ApplicationFields{
        .applicant = applicant_hex[0..64],
        .request_ref = verified_req.ref_hex[0..oa.ref_hex_len],
        .message = "I animate science explainers and would love this gig.",
        .stamp = "20260706.003000",
    };
    var canonical_app: [oa.max_oa_fact]u8 = undefined;
    const app_len = try oa.writeCanonicalApplication(app_fields, &canonical_app);
    const app_sig = applicant_kp.sign(canonical_app[0..app_len], null) catch unreachable;
    var app_payload: [oa.oa2_payload_header + oa.max_oa_fact]u8 = undefined;
    const app_payload_len = try oa.encodeCompactPayload(app_sig, canonical_app[0..app_len], &app_payload);
    const app_opened_len = try sealAndOpen(app_payload[0..app_payload_len], &opened);
    var app_fact_buf: [oa.max_oa_fact]u8 = undefined;
    var sig_buf: [Ed25519.Signature.encoded_length]u8 = undefined;
    const app_fact_len = try verifyApplicationPayload(opened[0..@intCast(app_opened_len)], applicant_pk, verified_req.ref_hex[0..oa.ref_hex_len], &sig_buf, &app_fact_buf);
    const wire_app_sig = Ed25519.Signature.fromBytes(sig_buf[0..Ed25519.Signature.encoded_length].*);

    const signed_acc = try buildSignedAcceptance(poster_kp, poster_hex[0..64], applicant_hex[0..64], verified_req.ref_hex[0..oa.ref_hex_len]);
    var acc_payload: [oa.oa2_payload_header + oa.max_oa_fact]u8 = undefined;
    const acc_payload_len = try oa.encodeCompactPayload(signed_acc.sig, signed_acc.canonical[0..signed_acc.canonical_len], &acc_payload);
    const acc_opened_len = try sealAndOpen(acc_payload[0..acc_payload_len], &opened);
    var acc_fact_buf: [oa.max_oa_fact]u8 = undefined;
    const acc_fact_len = try verifyAcceptancePayload(opened[0..@intCast(acc_opened_len)], poster_pk, verified_req.ref_hex[0..oa.ref_hex_len], applicant_hex[0..64], &sig_buf, &acc_fact_buf);
    const wire_acc_sig = Ed25519.Signature.fromBytes(sig_buf[0..Ed25519.Signature.encoded_length].*);

    const signed_pay = try buildSignedCompletion(poster_kp, poster_hex[0..64], applicant_hex[0..64], verified_req.ref_hex[0..oa.ref_hex_len], signed_req.stipend_buf[0..signed_req.stipend_len]);
    var pay_payload: [oa.oa2_payload_header + oa.max_oa_fact]u8 = undefined;
    const pay_payload_len = try oa.encodeCompactPayload(signed_pay.sig, signed_pay.canonical[0..signed_pay.canonical_len], &pay_payload);
    const pay_opened_len = try sealAndOpen(pay_payload[0..pay_payload_len], &opened);
    var pay_fact_buf: [oa.max_oa_fact]u8 = undefined;
    const pay_fact_len = try verifyCompletionPayload(opened[0..@intCast(pay_opened_len)], poster_pk, verified_req.ref_hex[0..oa.ref_hex_len], applicant_hex[0..64], 100, &sig_buf, &pay_fact_buf);
    const wire_pay_sig = Ed25519.Signature.fromBytes(sig_buf[0..Ed25519.Signature.encoded_length].*);

    const signed_consent = try buildSignedConsent(applicant_kp, applicant_hex[0..64], verified_req.ref_hex[0..oa.ref_hex_len]);
    var consent_payload: [oa.oa2_payload_header + oa.max_oa_fact]u8 = undefined;
    const consent_payload_len = try oa.encodeCompactPayload(signed_consent.sig, signed_consent.canonical[0..signed_consent.canonical_len], &consent_payload);
    const consent_opened_len = try sealAndOpen(consent_payload[0..consent_payload_len], &opened);
    var consent_fact_buf: [oa.max_oa_fact]u8 = undefined;
    const consent_fact_len = try verifyConsentPayload(opened[0..@intCast(consent_opened_len)], applicant_pk, verified_req.ref_hex[0..oa.ref_hex_len], oa.consent_grant, &sig_buf, &consent_fact_buf);
    const wire_consent_sig = Ed25519.Signature.fromBytes(sig_buf[0..Ed25519.Signature.encoded_length].*);

    return .{
        .signed_req_sig = signed_req.sig,
        .signed_req_canonical = signed_req.canonical,
        .signed_req_len = signed_req.canonical_len,
        .applicant_hex = applicant_hex,
        .wire_app_sig = wire_app_sig,
        .app_fact = app_fact_buf,
        .app_fact_len = app_fact_len,
        .wire_acc_sig = wire_acc_sig,
        .acc_fact = acc_fact_buf,
        .acc_fact_len = acc_fact_len,
        .wire_pay_sig = wire_pay_sig,
        .pay_fact = pay_fact_buf,
        .pay_fact_len = pay_fact_len,
        .wire_consent_sig = wire_consent_sig,
        .consent_fact = consent_fact_buf,
        .consent_fact_len = consent_fact_len,
    };
}

fn selftestOa5FoldAndReputation(
    wire: Oa5SelftestWire,
    poster_pk: Ed25519.PublicKey,
    applicant_pk: Ed25519.PublicKey,
) !void {
    var log: [oa.max_log_len]u8 = undefined;
    var log_len: u32 = 0;
    try appendSigned(wire.signed_req_sig, wire.signed_req_canonical[0..wire.signed_req_len], &log, &log_len);
    try appendSigned(wire.wire_app_sig, wire.app_fact[0..wire.app_fact_len], &log, &log_len);
    try appendSigned(wire.wire_acc_sig, wire.acc_fact[0..wire.acc_fact_len], &log, &log_len);
    try appendSigned(wire.wire_pay_sig, wire.pay_fact[0..wire.pay_fact_len], &log, &log_len);

    const cycle_len = log_len;
    const state = try oa.foldLog(log[0..cycle_len], poster_pk, applicant_pk);
    if (!state.completed or state.stipend != 100) return error.FoldFailed;

    try appendSigned(wire.wire_consent_sig, wire.consent_fact[0..wire.consent_fact_len], &log, &log_len);

    const rep = try oa.foldReputationLog(log[0..log_len], poster_pk, applicant_pk, wire.applicant_hex[0..64]);
    if (rep.consented_completions != 1 or rep.consented_stipend != 100) return error.FoldFailed;
}

fn runSelftest(io: std.Io) !u8 {
    const poster_kp = Ed25519.KeyPair.generateDeterministic(oa.poster_seed) catch unreachable;
    const applicant_kp = Ed25519.KeyPair.generateDeterministic(oa.applicant_seed) catch unreachable;
    const poster_pk = poster_kp.public_key;
    const applicant_pk = applicant_kp.public_key;

    const wire = try selftestOa5VerifyWireLegs(io, poster_kp, applicant_kp, poster_pk, applicant_pk);
    try selftestOa5FoldAndReputation(wire, poster_pk, applicant_pk);

    print("oal5: version {s} wire_format {s}\n", .{ oa5_version, wf.wire_format_version });
    print("GREEN: OA-L5 — accept, complete, consent crossed Comlink wire; fold and reputation GREEN.\n", .{});
    return 0;
}

fn runApplicant(_: std.Io) !u8 {
    const poster_kp = Ed25519.KeyPair.generateDeterministic(oa.poster_seed) catch unreachable;
    const applicant_kp = Ed25519.KeyPair.generateDeterministic(oa.applicant_seed) catch unreachable;
    const poster_pk = poster_kp.public_key;

    var wire: [@intCast(wf.wire_capacity)]u8 = undefined;
    const wire_len = try recvWire(applicant_port, &wire);
    if (wire_len < wf.off_cipher or wire_len > wf.wire_capacity) return error.RecvFailed;

    var opened: [@intCast(wf.max_message)]u8 = undefined;
    const opened_len = try openWire(wire[0..@intCast(wire_len)], &opened);
    var req_fact_buf: [oa.max_oa_fact]u8 = undefined;
    const verified = try verifyRequestPayload(opened[0..@intCast(opened_len)], poster_pk, &req_fact_buf);
    const stipend = blk: {
        var fields: oa.RequestFields = undefined;
        try oa.parseRequestFields(req_fact_buf[0..verified.fact_len], &fields);
        break :blk try rc.parseAmountSigned(fields.stipend);
    };

    var applicant_hex: [64]u8 = undefined;
    pubkeyHex(applicant_kp, &applicant_hex);

    const app_fields = oa.ApplicationFields{
        .applicant = applicant_hex[0..64],
        .request_ref = verified.ref_hex[0..oa.ref_hex_len],
        .message = "I animate science explainers and would love this gig.",
        .stamp = "20260706.003000",
    };
    var canonical_app: [oa.max_oa_fact]u8 = undefined;
    const app_len = try oa.writeCanonicalApplication(app_fields, &canonical_app);
    const app_sig = applicant_kp.sign(canonical_app[0..app_len], null) catch unreachable;
    var app_payload: [oa.oa2_payload_header + oa.max_oa_fact]u8 = undefined;
    const app_payload_len = try oa.encodeCompactPayload(app_sig, canonical_app[0..app_len], &app_payload);
    var out_wire: [@intCast(wf.wire_capacity)]u8 = undefined;
    const app_wire_len = try sealPayload(app_payload[0..app_payload_len], &out_wire);
    try sendWire(poster_port, out_wire[0..@intCast(app_wire_len)]);

    const acc_wire_len = try recvWire(applicant_port, &wire);
    const acc_opened_len = try openWire(wire[0..@intCast(acc_wire_len)], &opened);
    var sig_buf: [Ed25519.Signature.encoded_length]u8 = undefined;
    var acc_fact_buf: [oa.max_oa_fact]u8 = undefined;
    _ = try verifyAcceptancePayload(opened[0..@intCast(acc_opened_len)], poster_pk, verified.ref_hex[0..oa.ref_hex_len], applicant_hex[0..64], &sig_buf, &acc_fact_buf);

    const pay_wire_len = try recvWire(applicant_port, &wire);
    const pay_opened_len = try openWire(wire[0..@intCast(pay_wire_len)], &opened);
    var pay_fact_buf: [oa.max_oa_fact]u8 = undefined;
    _ = try verifyCompletionPayload(opened[0..@intCast(pay_opened_len)], poster_pk, verified.ref_hex[0..oa.ref_hex_len], applicant_hex[0..64], stipend, &sig_buf, &pay_fact_buf);

    const signed_consent = try buildSignedConsent(applicant_kp, applicant_hex[0..64], verified.ref_hex[0..oa.ref_hex_len]);
    var consent_payload: [oa.oa2_payload_header + oa.max_oa_fact]u8 = undefined;
    const consent_payload_len = try oa.encodeCompactPayload(signed_consent.sig, signed_consent.canonical[0..signed_consent.canonical_len], &consent_payload);
    const consent_wire_len = try sealPayload(consent_payload[0..consent_payload_len], &out_wire);
    try sendWire(poster_port, out_wire[0..@intCast(consent_wire_len)]);

    print("oal5: applicant returned application and consent — wire hops GREEN\n", .{});
    return 0;
}

fn runPoster(io: std.Io) !u8 {
    const poster_kp = Ed25519.KeyPair.generateDeterministic(oa.poster_seed) catch unreachable;
    const applicant_kp = Ed25519.KeyPair.generateDeterministic(oa.applicant_seed) catch unreachable;
    const poster_pk = poster_kp.public_key;
    const applicant_pk = applicant_kp.public_key;

    var poster_hex: [64]u8 = undefined;
    var applicant_hex: [64]u8 = undefined;
    pubkeyHex(poster_kp, &poster_hex);
    pubkeyHex(applicant_kp, &applicant_hex);

    const signed_req = try loadSignedRequest(io, poster_kp);
    var payload: [oa.oa2_payload_header + oa.max_oa_fact]u8 = undefined;
    const req_payload_len = try oa.encodeCompactPayload(signed_req.sig, signed_req.canonical[0..signed_req.canonical_len], &payload);
    var wire: [@intCast(wf.wire_capacity)]u8 = undefined;
    const req_wire_len = try sealPayload(payload[0..req_payload_len], &wire);
    try sendWire(applicant_port, wire[0..@intCast(req_wire_len)]);

    const app_recv_len = try recvWire(poster_port, &wire);
    var opened: [@intCast(wf.max_message)]u8 = undefined;
    const app_opened_len = try openWire(wire[0..@intCast(app_recv_len)], &opened);
    var app_fact_buf: [oa.max_oa_fact]u8 = undefined;
    var sig_buf: [Ed25519.Signature.encoded_length]u8 = undefined;
    const app_fact_len = try verifyApplicationPayload(opened[0..@intCast(app_opened_len)], applicant_pk, signed_req.ref_hex[0..oa.ref_hex_len], &sig_buf, &app_fact_buf);
    const app_sig = Ed25519.Signature.fromBytes(sig_buf[0..Ed25519.Signature.encoded_length].*);

    const signed_acc = try buildSignedAcceptance(poster_kp, poster_hex[0..64], applicant_hex[0..64], signed_req.ref_hex[0..oa.ref_hex_len]);
    const acc_payload_len = try oa.encodeCompactPayload(signed_acc.sig, signed_acc.canonical[0..signed_acc.canonical_len], &payload);
    const acc_wire_len = try sealPayload(payload[0..acc_payload_len], &wire);
    try sendWire(applicant_port, wire[0..@intCast(acc_wire_len)]);

    const signed_pay = try buildSignedCompletion(poster_kp, poster_hex[0..64], applicant_hex[0..64], signed_req.ref_hex[0..oa.ref_hex_len], signed_req.stipend_buf[0..signed_req.stipend_len]);
    const pay_payload_len = try oa.encodeCompactPayload(signed_pay.sig, signed_pay.canonical[0..signed_pay.canonical_len], &payload);
    const pay_wire_len = try sealPayload(payload[0..pay_payload_len], &wire);
    try sendWire(applicant_port, wire[0..@intCast(pay_wire_len)]);

    const consent_recv_len = try recvWire(poster_port, &wire);
    const consent_opened_len = try openWire(wire[0..@intCast(consent_recv_len)], &opened);
    var consent_fact_buf: [oa.max_oa_fact]u8 = undefined;
    const consent_fact_len = try verifyConsentPayload(opened[0..@intCast(consent_opened_len)], applicant_pk, signed_req.ref_hex[0..oa.ref_hex_len], oa.consent_grant, &sig_buf, &consent_fact_buf);
    const consent_sig = Ed25519.Signature.fromBytes(sig_buf[0..Ed25519.Signature.encoded_length].*);

    var acc_fact_buf: [oa.max_oa_fact]u8 = undefined;
    const acc_fact_len = signed_acc.canonical_len;
    tally_copy.copy_disjoint(u8, acc_fact_buf[0..acc_fact_len], signed_acc.canonical[0..acc_fact_len]);

    var pay_fact_buf: [oa.max_oa_fact]u8 = undefined;
    const pay_fact_len = signed_pay.canonical_len;
    tally_copy.copy_disjoint(u8, pay_fact_buf[0..pay_fact_len], signed_pay.canonical[0..pay_fact_len]);

    var log: [oa.max_log_len]u8 = undefined;
    var log_len: u32 = 0;
    try appendSigned(signed_req.sig, signed_req.canonical[0..signed_req.canonical_len], &log, &log_len);
    try appendSigned(app_sig, app_fact_buf[0..app_fact_len], &log, &log_len);
    try appendSigned(signed_acc.sig, acc_fact_buf[0..acc_fact_len], &log, &log_len);
    try appendSigned(signed_pay.sig, pay_fact_buf[0..pay_fact_len], &log, &log_len);

    const cycle_len = log_len;
    const state = try oa.foldLog(log[0..cycle_len], poster_pk, applicant_pk);
    if (!state.completed or state.stipend != 100) return error.FoldFailed;

    try appendSigned(consent_sig, consent_fact_buf[0..consent_fact_len], &log, &log_len);

    const rep = try oa.foldReputationLog(log[0..log_len], poster_pk, applicant_pk, applicant_hex[0..64]);
    if (rep.consented_completions != 1 or rep.consented_stipend != 100) return error.FoldFailed;

    print("oal5: poster folded full cycle with consent — GREEN\n", .{});
    return 0;
}

fn runDemo(allocator: std.mem.Allocator, io: std.Io, self_path: []const u8) !u8 {
    const applicant_argv = try allocator.alloc([]const u8, 2);
    applicant_argv[0] = self_path;
    applicant_argv[1] = "applicant";

    var applicant_child = try std.process.spawn(io, .{ .argv = applicant_argv });
    var pause = c.timespec{ .sec = 0, .nsec = 50_000_000 };
    _ = c.nanosleep(&pause, null);

    const poster_argv = try allocator.alloc([]const u8, 2);
    poster_argv[0] = self_path;
    poster_argv[1] = "poster";

    var poster_child = try std.process.spawn(io, .{ .argv = poster_argv });

    const applicant_term = try applicant_child.wait(io);
    const poster_term = try poster_child.wait(io);

    const applicant_code: u8 = switch (applicant_term) {
        .exited => |code| code,
        else => 255,
    };
    const poster_code: u8 = switch (poster_term) {
        .exited => |code| code,
        else => 255,
    };

    assert(applicant_code == 0);
    assert(poster_code == 0);

    print("oal5: demo GREEN — full ask cycle crossed localhost under Comlink seal\n", .{});
    print("oal5: version {s} wire_format {s}\n", .{ oa5_version, wf.wire_format_version });
    return 0;
}

pub fn main(init: std.process.Init) !u8 {
    const garden = init.arena.allocator();
    const io = init.io;
    const args = try init.minimal.args.toSlice(garden);

    if (args.len >= 2) {
        if (std.mem.eql(u8, args[1], "applicant")) return runApplicant(io);
        if (std.mem.eql(u8, args[1], "poster")) return runPoster(io);
        if (std.mem.eql(u8, args[1], "selftest")) return runSelftest(io);
        if (std.mem.eql(u8, args[1], "demo")) {
            assert(args.len >= 1);
            return runDemo(garden, io, args[0]);
        }
    }

    if (args.len >= 1) return runSelftest(io);
    return 1;
}
