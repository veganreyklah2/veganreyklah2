pub fn writeCanonicalAcceptance(fields: AcceptanceFields, out: []u8) error{Overflow}!u32 {
    const written = std.fmt.bufPrint(
        out,
        "poster {s}\nrequest_ref {s}\napplicant {s}\nstamp {s}\n",
        .{ fields.poster, fields.request_ref, fields.applicant, fields.stamp },
