pub fn parseConsentChoice(text: []const u8) error{InvalidFact}!ConsentChoice {
    if (std.mem.eql(u8, text, consent_grant)) return .grant;
    if (std.mem.eql(u8, text, consent_withhold)) return .withhold;
    return error.InvalidFact;
}

pub fn writeCanonicalConsent(fields: ConsentFields, out: []u8) error{Overflow}!u32 {
    const written = std.fmt.bufPrint(
        out,
        "applicant {s}\nrequest_ref {s}\nconsent {s}\nstamp {s}\n",
        .{ fields.applicant, fields.request_ref, fields.consent, fields.stamp },
    ) catch return error.Overflow;
    return bufLenU32(written);
}

fn findCycleByRef(cycles: []AskCycle, cycle_count: u32, ref_hex: []const u8) ?u32 {
    var i: u32 = 0;
    while (i < cycle_count) : (i += 1) {
        if (std.mem.eql(u8, cycles[i].request_ref[0..cycles[i].request_ref_len], ref_hex)) return i;
    }
    return null;
}

pub fn requestRefHex(canonical: []const u8, out: *[ref_hex_len]u8) void {
    var digest: [Sha3_256.digest_length]u8 = undefined;
    Sha3_256.hash(canonical, &digest, .{});
    var i: u32 = 0;
    while (i < Sha3_256.digest_length) : (i += 1) {
        _ = std.fmt.bufPrint(out[i * 2 ..][0..2], "{x:0>2}", .{digest[i]}) catch unreachable;
    }
}

fn factHasKey(text: []const u8, key: []const u8) bool {
    var lines = std.mem.splitScalar(u8, text, '\n');
    while (lines.next()) |raw| {
        const line = trimLine(raw);
        if (line.len == 0 or line[0] == '#') continue;
        const space = std.mem.indexOfScalar(u8, line, ' ');
        if (space) |s| {
            if (std.mem.eql(u8, line[0..s], key)) return true;
        }
    }
    return false;
}

pub fn classifyFact(fact: []const u8) error{InvalidFact}!enum { request, application, acceptance, completion, consent } {
    if (factHasKey(fact, "title")) return .request;
    if (factHasKey(fact, "message")) return .application;
    if (factHasKey(fact, "consent") and factHasKey(fact, "request_ref")) return .consent;
    if (factHasKey(fact, "from") and factHasKey(fact, "amount")) return .completion;
    if (factHasKey(fact, "request_ref") and factHasKey(fact, "applicant")) return .acceptance;
    return error.InvalidFact;
}

pub fn encodeCompactPayload(sig: Ed25519.Signature, fact: []const u8, out: []u8) error{Overflow}!u32 {
    if (fact.len > max_oa_fact) return error.Overflow;
    const total: u32 = oa2_payload_header + @as(u32, @intCast(fact.len));
    if (total > bufLenU32(out)) return error.Overflow;
    const sig_bytes = sig.toBytes();
    @memcpy(out[0..sig_bytes.len], &sig_bytes);
    std.mem.writeInt(u32, out[Ed25519.Signature.encoded_length..][0..4], @intCast(fact.len), .little);
    @memcpy(out[oa2_payload_header..][0..fact.len], fact);
    return total;
}

pub fn decodeCompactPayload(buf: []const u8, sig_out: []u8, fact_out: []u8) error{InvalidPayload}!struct { fact_len: u32 } {
    if (buf.len < oa2_payload_header) return error.InvalidPayload;
    const fact_len = std.mem.readInt(u32, buf[Ed25519.Signature.encoded_length..][0..4], .little);
    if (fact_len > max_oa_fact) return error.InvalidPayload;
    if (buf.len < oa2_payload_header + fact_len) return error.InvalidPayload;
    if (sig_out.len < Ed25519.Signature.encoded_length) return error.InvalidPayload;
    if (fact_out.len < fact_len) return error.InvalidPayload;
    @memcpy(sig_out[0..Ed25519.Signature.encoded_length], buf[0..Ed25519.Signature.encoded_length]);
    @memcpy(fact_out[0..fact_len], buf[oa2_payload_header..][0..fact_len]);
    return .{ .fact_len = fact_len };
}

pub fn foldAppliedLog(log: []const u8, poster_pk: Ed25519.PublicKey, applicant_pk: Ed25519.PublicKey) error{FoldFailed}!FoldState {
    var state: FoldState = .{};
    var pos: u32 = 0;
    while (pos < bufLenU32(log)) {
        const line_end = std.mem.indexOfScalarPos(u8, log, pos, '\n') orelse bufLenU32(log);
        const line = log[pos..line_end];
        pos = if (line_end < bufLenU32(log)) @as(u32, @intCast(line_end + 1)) else @as(u32, @intCast(line_end));
        if (trimLine(line).len == 0) continue;

        var sig_buf: [Ed25519.Signature.encoded_length]u8 = undefined;
        var fact_buf: [max_oa_fact]u8 = undefined;
        const parsed = rc.parseLogLine(line, &sig_buf, &fact_buf) catch return error.FoldFailed;
        const fact = fact_buf[0..parsed.fact_len];

        const kind = classifyFact(fact) catch return error.FoldFailed;
        switch (kind) {
            .request => {
                if (state.posted) return error.FoldFailed;
                var fields: RequestFields = undefined;
                parseRequestFields(fact, &fields) catch return error.FoldFailed;
                rc.verifyRecord(sig_buf[0..parsed.sig_len], fact, poster_pk) catch return error.FoldFailed;
                var poster_hex: [64]u8 = undefined;
                const poster_kp_bytes = poster_pk.toBytes();
                var i: u32 = 0;
                while (i < 32) : (i += 1) {
                    _ = std.fmt.bufPrint(poster_hex[i * 2 ..][0..2], "{x:0>2}", .{poster_kp_bytes[i]}) catch return error.FoldFailed;
                }
                if (!std.mem.eql(u8, fields.poster, poster_hex[0..64])) return error.FoldFailed;
                var ref_buf: [ref_hex_len]u8 = undefined;
                requestRefHex(fact, &ref_buf);
                @memcpy(state.request_ref[0..ref_hex_len], &ref_buf);
                state.request_ref_len = ref_hex_len;
                state.poster_hex_len = try copyHexField(fields.poster, &state.poster_hex);
                state.stipend = rc.parseAmountSigned(fields.stipend) catch return error.FoldFailed;
                state.posted = true;
            },
            .application => {
                if (!state.posted or state.applied) return error.FoldFailed;
                var fields: ApplicationFields = undefined;
                parseApplicationFields(fact, &fields) catch return error.FoldFailed;
                rc.verifyRecord(sig_buf[0..parsed.sig_len], fact, applicant_pk) catch return error.FoldFailed;
                if (!std.mem.eql(u8, fields.request_ref, state.request_ref[0..state.request_ref_len])) return error.FoldFailed;
                state.applicant_hex_len = try copyHexField(fields.applicant, &state.applicant_hex);
                state.applied = true;
            },
            .consent, .acceptance, .completion => return error.FoldFailed,
        }
    }
    if (!state.posted or !state.applied) return error.FoldFailed;
    return state;
}

pub fn foldLog(log: []const u8, poster_pk: Ed25519.PublicKey, applicant_pk: Ed25519.PublicKey) error{FoldFailed}!FoldState {
    var state: FoldState = .{};
    var pos: u32 = 0;
    while (pos < bufLenU32(log)) {
        const line_end = std.mem.indexOfScalarPos(u8, log, pos, '\n') orelse bufLenU32(log);
        const line = log[pos..line_end];
        pos = if (line_end < bufLenU32(log)) @as(u32, @intCast(line_end + 1)) else @as(u32, @intCast(line_end));
        if (trimLine(line).len == 0) continue;

        var sig_buf: [Ed25519.Signature.encoded_length]u8 = undefined;
        var fact_buf: [max_oa_fact]u8 = undefined;
        const parsed = rc.parseLogLine(line, &sig_buf, &fact_buf) catch return error.FoldFailed;
        const fact = fact_buf[0..parsed.fact_len];

        const kind = classifyFact(fact) catch return error.FoldFailed;
        switch (kind) {
            .request => {
                if (state.posted) return error.FoldFailed;
                var fields: RequestFields = undefined;
                parseRequestFields(fact, &fields) catch return error.FoldFailed;
                rc.verifyRecord(sig_buf[0..parsed.sig_len], fact, poster_pk) catch return error.FoldFailed;
                var poster_hex: [64]u8 = undefined;
                const poster_kp_bytes = poster_pk.toBytes();
                var i: u32 = 0;
                while (i < 32) : (i += 1) {
                    _ = std.fmt.bufPrint(poster_hex[i * 2 ..][0..2], "{x:0>2}", .{poster_kp_bytes[i]}) catch return error.FoldFailed;
                }
                if (!std.mem.eql(u8, fields.poster, poster_hex[0..64])) return error.FoldFailed;
                var ref_buf: [ref_hex_len]u8 = undefined;
                requestRefHex(fact, &ref_buf);
                @memcpy(state.request_ref[0..ref_hex_len], &ref_buf);
                state.request_ref_len = ref_hex_len;
                state.poster_hex_len = try copyHexField(fields.poster, &state.poster_hex);
                state.stipend = rc.parseAmountSigned(fields.stipend) catch return error.FoldFailed;
                state.posted = true;
            },
            .application => {
                if (!state.posted or state.applied) return error.FoldFailed;
                var fields: ApplicationFields = undefined;
                parseApplicationFields(fact, &fields) catch return error.FoldFailed;
                rc.verifyRecord(sig_buf[0..parsed.sig_len], fact, applicant_pk) catch return error.FoldFailed;
                if (!std.mem.eql(u8, fields.request_ref, state.request_ref[0..state.request_ref_len])) return error.FoldFailed;
                state.applicant_hex_len = try copyHexField(fields.applicant, &state.applicant_hex);
                state.applied = true;
            },
            .acceptance => {
                if (!state.applied or state.accepted) return error.FoldFailed;
                var fields: AcceptanceFields = undefined;
                parseAcceptanceFields(fact, &fields) catch return error.FoldFailed;
                rc.verifyRecord(sig_buf[0..parsed.sig_len], fact, poster_pk) catch return error.FoldFailed;
                if (!std.mem.eql(u8, fields.request_ref, state.request_ref[0..state.request_ref_len])) return error.FoldFailed;
                if (!std.mem.eql(u8, fields.applicant, state.applicant_hex[0..state.applicant_hex_len])) return error.FoldFailed;
                state.accepted = true;
            },
            .completion => {
                if (!state.accepted or state.completed) return error.FoldFailed;
                var fields: rc.FactFields = undefined;
                rc.parseFactFields(fact, &fields) catch return error.FoldFailed;
                rc.verifyRecord(sig_buf[0..parsed.sig_len], fact, poster_pk) catch return error.FoldFailed;
                const expected_memo_prefix = "completion request_ref=";
                if (!std.mem.startsWith(u8, fields.memo, expected_memo_prefix)) return error.FoldFailed;
                const memo_ref = fields.memo[expected_memo_prefix.len..];
                if (!std.mem.eql(u8, memo_ref, state.request_ref[0..state.request_ref_len])) return error.FoldFailed;
                const amount = rc.parseAmountSigned(fields.amount) catch return error.FoldFailed;
                if (amount != state.stipend) return error.FoldFailed;
                if (!std.mem.eql(u8, fields.to, state.applicant_hex[0..state.applicant_hex_len])) return error.FoldFailed;
                state.completed = true;
            },
            .consent => return error.FoldFailed,
        }
    }
    if (!state.completed) return error.FoldFailed;
    return state;
}

fn hexOfKey(pk: Ed25519.PublicKey, out: *[64]u8) void {
    const bytes = pk.toBytes();
    var i: u32 = 0;
    while (i < 32) : (i += 1) {
        _ = std.fmt.bufPrint(out[i * 2 ..][0..2], "{x:0>2}", .{bytes[i]}) catch unreachable;
    }
}

/// OA-L3 escrow fold: post, apply, accept, hold, release — on one log.
///
/// Invariants (stated first in the session log, enforced here):
///   - conservation: the release equals the held amount; the escrow balance
///     opens at zero, rises by the hold, and closes at zero on the release;
///   - the escrow balance is never negative at any step;
///   - a release reaches only the accepted applicant, only for the accepted
///     request, only in the held amount, and only after a matching hold;
///   - a hold requires a prior acceptance; no double-hold and no double-release;
///   - every escrow fact is poster-signed and every amount stays within bounds;
///   - internal only: own log, own keys, test units, no external chain.
pub fn foldEscrowLog(
    log: []const u8,
    poster_pk: Ed25519.PublicKey,
    applicant_pk: Ed25519.PublicKey,
    escrow_pk: Ed25519.PublicKey,
) error{FoldFailed}!FoldState {
    var state: FoldState = .{};

    var poster_hex: [64]u8 = undefined;
    hexOfKey(poster_pk, &poster_hex);
    var applicant_hex: [64]u8 = undefined;
    hexOfKey(applicant_pk, &applicant_hex);
    var escrow_hex: [64]u8 = undefined;
    hexOfKey(escrow_pk, &escrow_hex);

    var pos: u32 = 0;
    while (pos < bufLenU32(log)) {
        const line_end = std.mem.indexOfScalarPos(u8, log, pos, '\n') orelse bufLenU32(log);
        const line = log[pos..line_end];
        pos = if (line_end < bufLenU32(log)) @as(u32, @intCast(line_end + 1)) else @as(u32, @intCast(line_end));
        if (trimLine(line).len == 0) continue;

        var sig_buf: [Ed25519.Signature.encoded_length]u8 = undefined;
        var fact_buf: [max_oa_fact]u8 = undefined;
        const parsed = rc.parseLogLine(line, &sig_buf, &fact_buf) catch return error.FoldFailed;
        const fact = fact_buf[0..parsed.fact_len];

        const kind = classifyFact(fact) catch return error.FoldFailed;
        switch (kind) {
            .request => {
                if (state.posted) return error.FoldFailed;
                var fields: RequestFields = undefined;
                parseRequestFields(fact, &fields) catch return error.FoldFailed;
                rc.verifyRecord(sig_buf[0..parsed.sig_len], fact, poster_pk) catch return error.FoldFailed;
                if (!std.mem.eql(u8, fields.poster, poster_hex[0..64])) return error.FoldFailed;
                var ref_buf: [ref_hex_len]u8 = undefined;
                requestRefHex(fact, &ref_buf);
                @memcpy(state.request_ref[0..ref_hex_len], &ref_buf);
                state.request_ref_len = ref_hex_len;
                state.poster_hex_len = try copyHexField(fields.poster, &state.poster_hex);
                state.stipend = rc.parseAmountSigned(fields.stipend) catch return error.FoldFailed;
                if (state.stipend <= 0) return error.FoldFailed; // a bounty holds a positive stipend
                state.posted = true;
            },
            .application => {
                if (!state.posted or state.applied) return error.FoldFailed;
                var fields: ApplicationFields = undefined;
                parseApplicationFields(fact, &fields) catch return error.FoldFailed;
                rc.verifyRecord(sig_buf[0..parsed.sig_len], fact, applicant_pk) catch return error.FoldFailed;
                if (!std.mem.eql(u8, fields.request_ref, state.request_ref[0..state.request_ref_len])) return error.FoldFailed;
                state.applicant_hex_len = try copyHexField(fields.applicant, &state.applicant_hex);
                if (!std.mem.eql(u8, state.applicant_hex[0..state.applicant_hex_len], applicant_hex[0..64])) return error.FoldFailed;
                state.applied = true;
            },
            .acceptance => {
                if (!state.applied or state.accepted) return error.FoldFailed;
                var fields: AcceptanceFields = undefined;
                parseAcceptanceFields(fact, &fields) catch return error.FoldFailed;
                rc.verifyRecord(sig_buf[0..parsed.sig_len], fact, poster_pk) catch return error.FoldFailed;
                if (!std.mem.eql(u8, fields.request_ref, state.request_ref[0..state.request_ref_len])) return error.FoldFailed;
                if (!std.mem.eql(u8, fields.applicant, state.applicant_hex[0..state.applicant_hex_len])) return error.FoldFailed;
                state.accepted = true;
            },
            .completion => {
                // An escrow fact is a receipt-core payment whose memo names its role.
                var fields: rc.FactFields = undefined;
                rc.parseFactFields(fact, &fields) catch return error.FoldFailed;
                const role: EscrowRole = if (std.mem.startsWith(u8, fields.memo, escrow_hold_prefix))
                    .hold
                else if (std.mem.startsWith(u8, fields.memo, escrow_release_prefix))
                    .release
                else
                    return error.FoldFailed;
                rc.verifyRecord(sig_buf[0..parsed.sig_len], fact, poster_pk) catch return error.FoldFailed; // poster signs both legs
                const amount = rc.parseAmountSigned(fields.amount) catch return error.FoldFailed;
                const prefix = if (role == .hold) escrow_hold_prefix else escrow_release_prefix;
                const memo_ref = fields.memo[prefix.len..];
                if (!std.mem.eql(u8, memo_ref, state.request_ref[0..state.request_ref_len])) return error.FoldFailed;
                switch (role) {
                    .hold => {
                        if (!state.accepted or state.held) return error.FoldFailed;
                        if (amount != state.stipend) return error.FoldFailed;
                        if (!std.mem.eql(u8, fields.from, poster_hex[0..64])) return error.FoldFailed;
                        if (!std.mem.eql(u8, fields.to, escrow_hex[0..64])) return error.FoldFailed;
                        if (state.escrow_balance != 0) return error.FoldFailed; // opens at zero
                        state.escrow_balance += amount;
                        if (state.escrow_balance < 0) return error.FoldFailed; // never negative
                        state.held = true;
                    },
                    .release => {
                        if (!state.held or state.released) return error.FoldFailed;
                        if (amount != state.stipend) return error.FoldFailed;
                        if (amount != state.escrow_balance) return error.FoldFailed; // release exactly what is held
                        if (!std.mem.eql(u8, fields.from, escrow_hex[0..64])) return error.FoldFailed;
                        if (!std.mem.eql(u8, fields.to, state.applicant_hex[0..state.applicant_hex_len])) return error.FoldFailed;
                        state.escrow_balance -= amount;
                        if (state.escrow_balance != 0) return error.FoldFailed; // closes at zero
                        state.released = true;
                        state.completed = true;
                    },
                }
            },
            .consent => return error.FoldFailed,
        }
    }
    if (!state.posted or !state.applied or !state.accepted) return error.FoldFailed;
    if (!state.held or !state.released or !state.completed) return error.FoldFailed;
    if (state.escrow_balance != 0) return error.FoldFailed;
    return state;
}

/// OA-L4 reputation fold: many completed asks on one log; consent-before-counting
/// governs what may be tallied about an applicant.
///
/// Invariants:
///   - only completions with a matching applicant-signed consent `grant` count;
///   - `withhold` and missing consent exclude the bounty entirely;
///   - consent requires a prior completion for the same `request_ref`;
///   - no double consent on one bounty;
///   - the fold is deterministic — the same log always yields the same view.
pub fn foldReputationLog(
    log: []const u8,
    poster_pk: Ed25519.PublicKey,
    applicant_pk: Ed25519.PublicKey,
    target_applicant_hex: []const u8,
) error{FoldFailed}!ReputationFoldState {
    var cycles: [max_reputation_cycles]AskCycle = undefined;
    var cycle_count: u32 = 0;

    var poster_hex: [64]u8 = undefined;
    hexOfKey(poster_pk, &poster_hex);
    var applicant_hex: [64]u8 = undefined;
    hexOfKey(applicant_pk, &applicant_hex);

    var pos: u32 = 0;
    while (pos < bufLenU32(log)) {
        const line_end = std.mem.indexOfScalarPos(u8, log, pos, '\n') orelse bufLenU32(log);
        const line = log[pos..line_end];
        pos = if (line_end < bufLenU32(log)) @as(u32, @intCast(line_end + 1)) else @as(u32, @intCast(line_end));
        if (trimLine(line).len == 0) continue;

        var sig_buf: [Ed25519.Signature.encoded_length]u8 = undefined;
        var fact_buf: [max_oa_fact]u8 = undefined;
        const parsed = rc.parseLogLine(line, &sig_buf, &fact_buf) catch return error.FoldFailed;
        const fact = fact_buf[0..parsed.fact_len];

        const kind = classifyFact(fact) catch return error.FoldFailed;
        switch (kind) {
            .request => {
                if (cycle_count >= max_reputation_cycles) return error.FoldFailed;
                var fields: RequestFields = undefined;
                parseRequestFields(fact, &fields) catch return error.FoldFailed;
                rc.verifyRecord(sig_buf[0..parsed.sig_len], fact, poster_pk) catch return error.FoldFailed;
                if (!std.mem.eql(u8, fields.poster, poster_hex[0..64])) return error.FoldFailed;
                var ref_buf: [ref_hex_len]u8 = undefined;
                requestRefHex(fact, &ref_buf);
                if (findCycleByRef(cycles[0..], cycle_count, ref_buf[0..ref_hex_len]) != null) return error.FoldFailed;
                cycles[cycle_count] = .{};
                var cycle = &cycles[cycle_count];
                @memcpy(cycle.request_ref[0..ref_hex_len], &ref_buf);
                cycle.request_ref_len = ref_hex_len;
                cycle.stipend = rc.parseAmountSigned(fields.stipend) catch return error.FoldFailed;
                cycle_count += 1;
            },
            .application => {
                var fields: ApplicationFields = undefined;
                parseApplicationFields(fact, &fields) catch return error.FoldFailed;
                rc.verifyRecord(sig_buf[0..parsed.sig_len], fact, applicant_pk) catch return error.FoldFailed;
                const idx = findCycleByRef(cycles[0..], cycle_count, fields.request_ref) orelse return error.FoldFailed;
                var cycle = &cycles[idx];
                if (cycle.applicant_hex_len != 0) return error.FoldFailed;
                cycle.applicant_hex_len = try copyHexField(fields.applicant, &cycle.applicant_hex);
                if (!std.mem.eql(u8, cycle.applicant_hex[0..cycle.applicant_hex_len], applicant_hex[0..64])) return error.FoldFailed;
            },
            .acceptance => {
                var fields: AcceptanceFields = undefined;
                parseAcceptanceFields(fact, &fields) catch return error.FoldFailed;
                rc.verifyRecord(sig_buf[0..parsed.sig_len], fact, poster_pk) catch return error.FoldFailed;
                const idx = findCycleByRef(cycles[0..], cycle_count, fields.request_ref) orelse return error.FoldFailed;
                const cycle = &cycles[idx];
                if (cycle.applicant_hex_len == 0) return error.FoldFailed;
                if (!std.mem.eql(u8, fields.applicant, cycle.applicant_hex[0..cycle.applicant_hex_len])) return error.FoldFailed;
            },
            .completion => {
                var fields: rc.FactFields = undefined;
                rc.parseFactFields(fact, &fields) catch return error.FoldFailed;
                rc.verifyRecord(sig_buf[0..parsed.sig_len], fact, poster_pk) catch return error.FoldFailed;
                const expected_memo_prefix = "completion request_ref=";
                if (!std.mem.startsWith(u8, fields.memo, expected_memo_prefix)) return error.FoldFailed;
                const memo_ref = fields.memo[expected_memo_prefix.len..];
                const idx = findCycleByRef(cycles[0..], cycle_count, memo_ref) orelse return error.FoldFailed;
                var cycle = &cycles[idx];
                if (cycle.completed) return error.FoldFailed;
                if (cycle.applicant_hex_len == 0) return error.FoldFailed;
                const amount = rc.parseAmountSigned(fields.amount) catch return error.FoldFailed;
                if (amount != cycle.stipend) return error.FoldFailed;
                if (!std.mem.eql(u8, fields.to, cycle.applicant_hex[0..cycle.applicant_hex_len])) return error.FoldFailed;
                cycle.completed = true;
            },
            .consent => {
                var fields: ConsentFields = undefined;
                parseConsentFields(fact, &fields) catch return error.FoldFailed;
                rc.verifyRecord(sig_buf[0..parsed.sig_len], fact, applicant_pk) catch return error.FoldFailed;
                const choice = parseConsentChoice(fields.consent) catch return error.FoldFailed;
                const idx = findCycleByRef(cycles[0..], cycle_count, fields.request_ref) orelse return error.FoldFailed;
                var cycle = &cycles[idx];
                if (!cycle.completed) return error.FoldFailed;
                if (cycle.consent != .none) return error.FoldFailed;
                if (!std.mem.eql(u8, fields.applicant, cycle.applicant_hex[0..cycle.applicant_hex_len])) return error.FoldFailed;
                cycle.consent = switch (choice) {
                    .grant => .grant,
                    .withhold => .withhold,
                };
            },
        }
    }

    var result: ReputationFoldState = .{};
    var i: u32 = 0;
    while (i < cycle_count) : (i += 1) {
        const cycle = cycles[i];
        if (!cycle.completed) continue;
        if (!std.mem.eql(u8, cycle.applicant_hex[0..cycle.applicant_hex_len], target_applicant_hex)) continue;
        if (cycle.consent != .grant) continue;
        result.consented_completions += 1;
        result.consented_stipend += cycle.stipend;
    }
    return result;
}

fn appendSigned(sig: Ed25519.Signature, fact: []const u8, log: []u8, log_len: *u32) error{Overflow}!void {
    var line: [max_line_len]u8 = undefined;
    const line_len = try rc.formatLogLine(sig, fact, &line);
    if (log_len.* + line_len > bufLenU32(log)) return error.Overflow;
    @memcpy(log[log_len.*..][0..line_len], line[0..line_len]);
    log_len.* += line_len;
}

fn pubkeyHex(kp: Ed25519.KeyPair, out: *[64]u8) void {
    const bytes = kp.public_key.toBytes();
    var i: u32 = 0;
    while (i < 32) : (i += 1) {
        _ = std.fmt.bufPrint(out[i * 2 ..][0..2], "{x:0>2}", .{bytes[i]}) catch unreachable;
    }
}

fn runSelftest(io: std.Io) !u8 {
    const poster_kp = Ed25519.KeyPair.generateDeterministic(oa1_poster_seed) catch unreachable;
    const applicant_kp = Ed25519.KeyPair.generateDeterministic(oa1_applicant_seed) catch unreachable;
    const poster_pk = poster_kp.public_key;
    const applicant_pk = applicant_kp.public_key;

    var poster_hex: [64]u8 = undefined;
    var applicant_hex: [64]u8 = undefined;
    pubkeyHex(poster_kp, &poster_hex);
    pubkeyHex(applicant_kp, &applicant_hex);

    const fixture_path = "tools/fixtures/open_asks_request.bron";
    const cwd = Dir.cwd();
    var fixture_buf: [max_oa_fact]u8 = undefined;
    const fixture_read = try cwd.readFile(io, fixture_path, &fixture_buf);
    assert(fixture_read.len <= max_oa_fact);

    var req_fields: RequestFields = undefined;
    try parseRequestFields(fixture_read, &req_fields);
    assert(std.mem.eql(u8, req_fields.poster, poster_hex[0..64]));

    var canonical_req: [max_oa_fact]u8 = undefined;
    const req_len = try writeCanonicalRequest(req_fields, &canonical_req);

    var ref_hex: [ref_hex_len]u8 = undefined;
    requestRefHex(canonical_req[0..req_len], &ref_hex);

    var log: [max_log_len]u8 = undefined;
    var log_len: u32 = 0;

    const req_sig = poster_kp.sign(canonical_req[0..req_len], null) catch unreachable;
    try appendSigned(req_sig, canonical_req[0..req_len], &log, &log_len);

    const app_fields = ApplicationFields{
        .applicant = applicant_hex[0..64],
        .request_ref = ref_hex[0..ref_hex_len],
        .message = "I animate science explainers and would love this gig.",
        .stamp = "20260706.003000",
    };
    var canonical_app: [max_oa_fact]u8 = undefined;
    const app_len = try writeCanonicalApplication(app_fields, &canonical_app);
    const app_sig = applicant_kp.sign(canonical_app[0..app_len], null) catch unreachable;
    try appendSigned(app_sig, canonical_app[0..app_len], &log, &log_len);

    const acc_fields = AcceptanceFields{
        .poster = poster_hex[0..64],
        .request_ref = ref_hex[0..ref_hex_len],
        .applicant = applicant_hex[0..64],
        .stamp = "20260706.003100",
    };
    var canonical_acc: [max_oa_fact]u8 = undefined;
    const acc_len = try writeCanonicalAcceptance(acc_fields, &canonical_acc);
    const acc_sig = poster_kp.sign(canonical_acc[0..acc_len], null) catch unreachable;
    try appendSigned(acc_sig, canonical_acc[0..acc_len], &log, &log_len);

    var memo_buf: [128]u8 = undefined;
    const memo_written = try std.fmt.bufPrint(&memo_buf, "completion request_ref={s}", .{ref_hex[0..ref_hex_len]});
    const completion_fields = rc.FactFields{
        .from = poster_hex[0..64],
        .to = applicant_hex[0..64],
        .amount = req_fields.stipend,
        .memo = memo_written,
        .stamp = "20260706.003200",
    };
    var canonical_pay: [max_oa_fact]u8 = undefined;
    const pay_len = try rc.writeCanonicalFact(completion_fields, &canonical_pay);
    const pay_sig = poster_kp.sign(canonical_pay[0..pay_len], null) catch unreachable;
    try appendSigned(pay_sig, canonical_pay[0..pay_len], &log, &log_len);

    const state = try foldLog(log[0..log_len], poster_pk, applicant_pk);
    assert(state.completed);
    assert(state.stipend == 100);

    var bad_ref: [ref_hex_len]u8 = undefined;
    @memset(&bad_ref, '0');
    const bad_app = ApplicationFields{
        .applicant = applicant_hex[0..64],
        .request_ref = bad_ref[0..ref_hex_len],
        .message = app_fields.message,
        .stamp = app_fields.stamp,
    };
    var bad_canonical: [max_oa_fact]u8 = undefined;
    const bad_len = try writeCanonicalApplication(bad_app, &bad_canonical);
    const bad_sig = applicant_kp.sign(bad_canonical[0..bad_len], null) catch unreachable;
    var bad_log: [max_log_len]u8 = undefined;
    var bad_log_len: u32 = 0;
    try appendSigned(req_sig, canonical_req[0..req_len], &bad_log, &bad_log_len);
    try appendSigned(bad_sig, bad_canonical[0..bad_len], &bad_log, &bad_log_len);
    _ = foldLog(bad_log[0..bad_log_len], poster_pk, applicant_pk) catch {
        print("oal1: bad request_ref refused at fold — GREEN unwelcome path\n", .{});
        print("oal1: version {s}\n", .{oa1_version});
        print("GREEN: OA-L1 closed ask loop — post, apply, accept, complete, verify.\n", .{});
        return 0;
    };
    return error.UnwelcomePassed;
}

const EscrowKeys = struct {
    poster: Ed25519.KeyPair,
    applicant: Ed25519.KeyPair,
    escrow: Ed25519.KeyPair,
    poster_hex: [64]u8,
    applicant_hex: [64]u8,
    escrow_hex: [64]u8,
};

fn buildAcceptedPrefix(keys: EscrowKeys, req_fields: RequestFields, ref_hex: []const u8, log: []u8, log_len: *u32) !void {
    var canonical_req: [max_oa_fact]u8 = undefined;
    const req_len = try writeCanonicalRequest(req_fields, &canonical_req);
    const req_sig = keys.poster.sign(canonical_req[0..req_len], null) catch unreachable;
    try appendSigned(req_sig, canonical_req[0..req_len], log, log_len);

    const app_fields = ApplicationFields{
        .applicant = keys.applicant_hex[0..64],
        .request_ref = ref_hex,
        .message = "I animate science explainers and would love this gig.",
        .stamp = "20260706.003000",
    };
    var canonical_app: [max_oa_fact]u8 = undefined;
    const app_len = try writeCanonicalApplication(app_fields, &canonical_app);
    const app_sig = keys.applicant.sign(canonical_app[0..app_len], null) catch unreachable;
    try appendSigned(app_sig, canonical_app[0..app_len], log, log_len);

    const acc_fields = AcceptanceFields{
        .poster = keys.poster_hex[0..64],
        .request_ref = ref_hex,
        .applicant = keys.applicant_hex[0..64],
        .stamp = "20260706.003100",
    };
    var canonical_acc: [max_oa_fact]u8 = undefined;
    const acc_len = try writeCanonicalAcceptance(acc_fields, &canonical_acc);
    const acc_sig = keys.poster.sign(canonical_acc[0..acc_len], null) catch unreachable;
    try appendSigned(acc_sig, canonical_acc[0..acc_len], log, log_len);
}

fn buildEscrowFact(
    signer: Ed25519.KeyPair,
    role: EscrowRole,
    from_hex: []const u8,
    to_hex: []const u8,
    amount_text: []const u8,
    ref_hex: []const u8,
    stamp: []const u8,
    log: []u8,
    log_len: *u32,
) !void {
    var canonical: [max_oa_fact]u8 = undefined;
    const clen = try writeEscrowPaymentCanonical(role, from_hex, to_hex, amount_text, ref_hex, stamp, &canonical);
    const sig = signer.sign(canonical[0..clen], null) catch unreachable;
    try appendSigned(sig, canonical[0..clen], log, log_len);
}

/// Canonical bytes for a poster-signed escrow payment fact (hold or release).
pub fn writeEscrowPaymentCanonical(
    role: EscrowRole,
    from_hex: []const u8,
    to_hex: []const u8,
    amount_text: []const u8,
    ref_hex: []const u8,
    stamp: []const u8,
    out: []u8,
) error{Overflow}!u32 {
    const prefix = if (role == .hold) escrow_hold_prefix else escrow_release_prefix;
    var memo_buf: [128]u8 = undefined;
    const memo = std.fmt.bufPrint(&memo_buf, "{s}{s}", .{ prefix, ref_hex }) catch return error.Overflow;
    const fields = rc.FactFields{ .from = from_hex, .to = to_hex, .amount = amount_text, .memo = memo, .stamp = stamp };
    return try rc.writeCanonicalFact(fields, out);
}

fn runEscrowSelftest(io: std.Io) !u8 {
    const poster_kp = Ed25519.KeyPair.generateDeterministic(oa1_poster_seed) catch unreachable;
    const applicant_kp = Ed25519.KeyPair.generateDeterministic(oa1_applicant_seed) catch unreachable;
    const escrow_kp = Ed25519.KeyPair.generateDeterministic(escrow_seed) catch unreachable;

    var keys: EscrowKeys = .{
        .poster = poster_kp,
        .applicant = applicant_kp,
        .escrow = escrow_kp,
        .poster_hex = undefined,
        .applicant_hex = undefined,
        .escrow_hex = undefined,
    };
    hexOfKey(poster_kp.public_key, &keys.poster_hex);
    hexOfKey(applicant_kp.public_key, &keys.applicant_hex);
    hexOfKey(escrow_kp.public_key, &keys.escrow_hex);

    const cwd = Dir.cwd();
    var fixture_buf: [max_oa_fact]u8 = undefined;
    const fixture_read = try cwd.readFile(io, "tools/fixtures/open_asks_request.bron", &fixture_buf);
    var req_fields: RequestFields = undefined;
    try parseRequestFields(fixture_read, &req_fields);
    assert(std.mem.eql(u8, req_fields.poster, keys.poster_hex[0..64]));

    var canonical_req: [max_oa_fact]u8 = undefined;
    const req_len = try writeCanonicalRequest(req_fields, &canonical_req);
    var ref_hex: [ref_hex_len]u8 = undefined;
    requestRefHex(canonical_req[0..req_len], &ref_hex);
    const stipend_text = req_fields.stipend;

    // Welcome path: post, apply, accept, hold, release.
    var log: [max_log_len]u8 = undefined;
    var log_len: u32 = 0;
    try buildAcceptedPrefix(keys, req_fields, ref_hex[0..ref_hex_len], &log, &log_len);
    try buildEscrowFact(poster_kp, .hold, keys.poster_hex[0..64], keys.escrow_hex[0..64], stipend_text, ref_hex[0..ref_hex_len], "20260706.003200", &log, &log_len);
    try buildEscrowFact(poster_kp, .release, keys.escrow_hex[0..64], keys.applicant_hex[0..64], stipend_text, ref_hex[0..ref_hex_len], "20260706.003300", &log, &log_len);

    const state = try foldEscrowLog(log[0..log_len], poster_kp.public_key, applicant_kp.public_key, escrow_kp.public_key);
    assert(state.held);
    assert(state.released);
    assert(state.completed);
    assert(state.escrow_balance == 0);
    assert(state.stipend == 100);
    print("oal3: hold then release folded — escrow closes at {d}, stipend {d}\n", .{ state.escrow_balance, state.stipend });

    // Unwelcome path 1 — release with no prior hold.
    {
        var bad: [max_log_len]u8 = undefined;
        var bl: u32 = 0;
        try buildAcceptedPrefix(keys, req_fields, ref_hex[0..ref_hex_len], &bad, &bl);
        try buildEscrowFact(poster_kp, .release, keys.escrow_hex[0..64], keys.applicant_hex[0..64], stipend_text, ref_hex[0..ref_hex_len], "20260706.003300", &bad, &bl);
        if (foldEscrowLog(bad[0..bl], poster_kp.public_key, applicant_kp.public_key, escrow_kp.public_key)) |_| {
            return error.UnwelcomePassed;
        } else |_| print("oal3: release without hold refused — GREEN unwelcome path\n", .{});
    }

    // Unwelcome path 2 — release in the wrong amount.
    {
        var bad: [max_log_len]u8 = undefined;
        var bl: u32 = 0;
        try buildAcceptedPrefix(keys, req_fields, ref_hex[0..ref_hex_len], &bad, &bl);
        try buildEscrowFact(poster_kp, .hold, keys.poster_hex[0..64], keys.escrow_hex[0..64], stipend_text, ref_hex[0..ref_hex_len], "20260706.003200", &bad, &bl);
        try buildEscrowFact(poster_kp, .release, keys.escrow_hex[0..64], keys.applicant_hex[0..64], "50", ref_hex[0..ref_hex_len], "20260706.003300", &bad, &bl);
        if (foldEscrowLog(bad[0..bl], poster_kp.public_key, applicant_kp.public_key, escrow_kp.public_key)) |_| {
            return error.UnwelcomePassed;
        } else |_| print("oal3: wrong-amount release refused — GREEN unwelcome path\n", .{});
    }

    // Unwelcome path 3 — release to the wrong applicant.
    {
        var bad: [max_log_len]u8 = undefined;
        var bl: u32 = 0;
        try buildAcceptedPrefix(keys, req_fields, ref_hex[0..ref_hex_len], &bad, &bl);
        try buildEscrowFact(poster_kp, .hold, keys.poster_hex[0..64], keys.escrow_hex[0..64], stipend_text, ref_hex[0..ref_hex_len], "20260706.003200", &bad, &bl);
        try buildEscrowFact(poster_kp, .release, keys.escrow_hex[0..64], keys.poster_hex[0..64], stipend_text, ref_hex[0..ref_hex_len], "20260706.003300", &bad, &bl);
        if (foldEscrowLog(bad[0..bl], poster_kp.public_key, applicant_kp.public_key, escrow_kp.public_key)) |_| {
            return error.UnwelcomePassed;
        } else |_| print("oal3: wrong-applicant release refused — GREEN unwelcome path\n", .{});
    }

    // Unwelcome path 4 — a second release on a settled bounty.
    {
        var bad: [max_log_len]u8 = undefined;
        var bl: u32 = 0;
        try buildAcceptedPrefix(keys, req_fields, ref_hex[0..ref_hex_len], &bad, &bl);
        try buildEscrowFact(poster_kp, .hold, keys.poster_hex[0..64], keys.escrow_hex[0..64], stipend_text, ref_hex[0..ref_hex_len], "20260706.003200", &bad, &bl);
        try buildEscrowFact(poster_kp, .release, keys.escrow_hex[0..64], keys.applicant_hex[0..64], stipend_text, ref_hex[0..ref_hex_len], "20260706.003300", &bad, &bl);
        try buildEscrowFact(poster_kp, .release, keys.escrow_hex[0..64], keys.applicant_hex[0..64], stipend_text, ref_hex[0..ref_hex_len], "20260706.003400", &bad, &bl);
        if (foldEscrowLog(bad[0..bl], poster_kp.public_key, applicant_kp.public_key, escrow_kp.public_key)) |_| {
            return error.UnwelcomePassed;
        } else |_| print("oal3: double release refused — GREEN unwelcome path\n", .{});
    }

    // Unwelcome path 5 — a second hold on the same request.
    {
        var bad: [max_log_len]u8 = undefined;
        var bl: u32 = 0;
        try buildAcceptedPrefix(keys, req_fields, ref_hex[0..ref_hex_len], &bad, &bl);
        try buildEscrowFact(poster_kp, .hold, keys.poster_hex[0..64], keys.escrow_hex[0..64], stipend_text, ref_hex[0..ref_hex_len], "20260706.003200", &bad, &bl);
        try buildEscrowFact(poster_kp, .hold, keys.poster_hex[0..64], keys.escrow_hex[0..64], stipend_text, ref_hex[0..ref_hex_len], "20260706.003250", &bad, &bl);
        if (foldEscrowLog(bad[0..bl], poster_kp.public_key, applicant_kp.public_key, escrow_kp.public_key)) |_| {
            return error.UnwelcomePassed;
        } else |_| print("oal3: double hold refused — GREEN unwelcome path\n", .{});
    }

    print("oal3: version {s}\n", .{oa1_version});
    print("GREEN: OA-L3 escrow — hold, release, verify on one log.\n", .{});
    return 0;
}

fn appendCompletedAsk(
    poster_kp: Ed25519.KeyPair,
    applicant_kp: Ed25519.KeyPair,
    poster_hex: []const u8,
    applicant_hex: []const u8,
    req_fields: RequestFields,
    consent: ?ConsentChoice,
    log: []u8,
    log_len: *u32,
) !void {
    var canonical_req: [max_oa_fact]u8 = undefined;
    const req_len = try writeCanonicalRequest(req_fields, &canonical_req);
    const req_sig = poster_kp.sign(canonical_req[0..req_len], null) catch unreachable;
    try appendSigned(req_sig, canonical_req[0..req_len], log, log_len);

    var ref_hex: [ref_hex_len]u8 = undefined;
    requestRefHex(canonical_req[0..req_len], &ref_hex);

    const app_fields = ApplicationFields{
        .applicant = applicant_hex,
        .request_ref = ref_hex[0..ref_hex_len],
        .message = "Completed work for reputation witness.",
        .stamp = req_fields.stamp,
    };
    var canonical_app: [max_oa_fact]u8 = undefined;
    const app_len = try writeCanonicalApplication(app_fields, &canonical_app);
    const app_sig = applicant_kp.sign(canonical_app[0..app_len], null) catch unreachable;
    try appendSigned(app_sig, canonical_app[0..app_len], log, log_len);

    const acc_fields = AcceptanceFields{
        .poster = poster_hex,
        .request_ref = ref_hex[0..ref_hex_len],
        .applicant = applicant_hex,
        .stamp = req_fields.stamp,
    };
    var canonical_acc: [max_oa_fact]u8 = undefined;
    const acc_len = try writeCanonicalAcceptance(acc_fields, &canonical_acc);
    const acc_sig = poster_kp.sign(canonical_acc[0..acc_len], null) catch unreachable;
    try appendSigned(acc_sig, canonical_acc[0..acc_len], log, log_len);

    var memo_buf: [128]u8 = undefined;
    const memo_written = try std.fmt.bufPrint(&memo_buf, "completion request_ref={s}", .{ref_hex[0..ref_hex_len]});
    const completion_fields = rc.FactFields{
        .from = poster_hex,
        .to = applicant_hex,
        .amount = req_fields.stipend,
        .memo = memo_written,
        .stamp = req_fields.stamp,
    };
    var canonical_pay: [max_oa_fact]u8 = undefined;
    const pay_len = try rc.writeCanonicalFact(completion_fields, &canonical_pay);
    const pay_sig = poster_kp.sign(canonical_pay[0..pay_len], null) catch unreachable;
    try appendSigned(pay_sig, canonical_pay[0..pay_len], log, log_len);

    if (consent) |choice| {
        const consent_text = if (choice == .grant) consent_grant else consent_withhold;
        const consent_fields = ConsentFields{
            .applicant = applicant_hex,
            .request_ref = ref_hex[0..ref_hex_len],
            .consent = consent_text,
            .stamp = req_fields.stamp,
        };
        var canonical_consent: [max_oa_fact]u8 = undefined;
        const consent_len = try writeCanonicalConsent(consent_fields, &canonical_consent);
        const consent_sig = applicant_kp.sign(canonical_consent[0..consent_len], null) catch unreachable;
        try appendSigned(consent_sig, canonical_consent[0..consent_len], log, log_len);
    }
}

fn runReputationSelftest(io: std.Io) !u8 {
    _ = io;
    const poster_kp = Ed25519.KeyPair.generateDeterministic(oa1_poster_seed) catch unreachable;
    const applicant_kp = Ed25519.KeyPair.generateDeterministic(oa1_applicant_seed) catch unreachable;

    var poster_hex: [64]u8 = undefined;
    var applicant_hex: [64]u8 = undefined;
    hexOfKey(poster_kp.public_key, &poster_hex);
    hexOfKey(applicant_kp.public_key, &applicant_hex);

    var log: [max_log_len]u8 = undefined;
    var log_len: u32 = 0;

    // Witness bolt: three completed asks — two grant, one withhold.
    const req_a = RequestFields{
        .poster = poster_hex[0..64],
        .title = "animator gig alpha",
        .skills = "animation",
        .bounds = "remote",
        .stipend = "100",
        .deadline = "20260715.235959",
        .stamp = "20260706.234500",
    };
    const req_b = RequestFields{
        .poster = poster_hex[0..64],
        .title = "animator gig beta",
        .skills = "animation",
        .bounds = "remote",
        .stipend = "100",
        .deadline = "20260716.235959",
        .stamp = "20260706.234501",
    };
    const req_c = RequestFields{
        .poster = poster_hex[0..64],
        .title = "animator gig gamma",
        .skills = "animation",
        .bounds = "remote",
        .stipend = "100",
        .deadline = "20260717.235959",
        .stamp = "20260706.234502",
    };

    try appendCompletedAsk(poster_kp, applicant_kp, poster_hex[0..64], applicant_hex[0..64], req_a, .grant, &log, &log_len);
    try appendCompletedAsk(poster_kp, applicant_kp, poster_hex[0..64], applicant_hex[0..64], req_b, .grant, &log, &log_len);
    try appendCompletedAsk(poster_kp, applicant_kp, poster_hex[0..64], applicant_hex[0..64], req_c, .withhold, &log, &log_len);

    const view_a = try foldReputationLog(log[0..log_len], poster_kp.public_key, applicant_kp.public_key, applicant_hex[0..64]);
    const view_b = try foldReputationLog(log[0..log_len], poster_kp.public_key, applicant_kp.public_key, applicant_hex[0..64]);
    assert(view_a.consented_completions == view_b.consented_completions);
    assert(view_a.consented_stipend == view_b.consented_stipend);
    assert(view_a.consented_completions == 2);
    assert(view_a.consented_stipend == 200);
    print("oal4: consented completions {d}, stipend {d} — withheld bounty excluded\n", .{ view_a.consented_completions, view_a.consented_stipend });

    // Unwelcome path — consent before completion.
    {
        var bad: [max_log_len]u8 = undefined;
        var bl: u32 = 0;
        var canonical_req: [max_oa_fact]u8 = undefined;
        const req_len = try writeCanonicalRequest(req_a, &canonical_req);
        const req_sig = poster_kp.sign(canonical_req[0..req_len], null) catch unreachable;
        try appendSigned(req_sig, canonical_req[0..req_len], &bad, &bl);
        var ref_hex: [ref_hex_len]u8 = undefined;
        requestRefHex(canonical_req[0..req_len], &ref_hex);
        const consent_fields = ConsentFields{
            .applicant = applicant_hex[0..64],
            .request_ref = ref_hex[0..ref_hex_len],
            .consent = consent_grant,
            .stamp = "20260706.234599",
        };
        var canonical_consent: [max_oa_fact]u8 = undefined;
        const consent_len = try writeCanonicalConsent(consent_fields, &canonical_consent);
        const consent_sig = applicant_kp.sign(canonical_consent[0..consent_len], null) catch unreachable;
        try appendSigned(consent_sig, canonical_consent[0..consent_len], &bad, &bl);
        if (foldReputationLog(bad[0..bl], poster_kp.public_key, applicant_kp.public_key, applicant_hex[0..64])) |_| {
            return error.UnwelcomePassed;
        } else |_| print("oal4: consent before completion refused — GREEN unwelcome path\n", .{});
    }

    // Unwelcome path — double consent on one bounty.
    {
        var bad: [max_log_len]u8 = undefined;
        var bl: u32 = 0;
        try appendCompletedAsk(poster_kp, applicant_kp, poster_hex[0..64], applicant_hex[0..64], req_a, .grant, &bad, &bl);
        var canonical_req: [max_oa_fact]u8 = undefined;
        const req_len = try writeCanonicalRequest(req_a, &canonical_req);
        var ref_hex: [ref_hex_len]u8 = undefined;
        requestRefHex(canonical_req[0..req_len], &ref_hex);
        const consent_fields = ConsentFields{
            .applicant = applicant_hex[0..64],
            .request_ref = ref_hex[0..ref_hex_len],
            .consent = consent_grant,
            .stamp = "20260706.234600",
        };
        var canonical_consent: [max_oa_fact]u8 = undefined;
        const consent_len = try writeCanonicalConsent(consent_fields, &canonical_consent);
        const consent_sig = applicant_kp.sign(canonical_consent[0..consent_len], null) catch unreachable;
        try appendSigned(consent_sig, canonical_consent[0..consent_len], &bad, &bl);
        if (foldReputationLog(bad[0..bl], poster_kp.public_key, applicant_kp.public_key, applicant_hex[0..64])) |_| {
            return error.UnwelcomePassed;
        } else |_| print("oal4: double consent refused — GREEN unwelcome path\n", .{});
    }

    print("oal4: version {s}\n", .{oa1_version});
    print("GREEN: OA-L4 reputation-as-fold — consent-before-counting on one log.\n", .{});
    return 0;
}

pub fn main(init: std.process.Init) !u8 {
    const garden = init.arena.allocator();
    const io = init.io;
    const args = try init.minimal.args.toSlice(garden);
    if (args.len >= 2 and std.mem.eql(u8, args[1], "selftest")) return runSelftest(io);
    if (args.len >= 2 and std.mem.eql(u8, args[1], "escrow")) return runEscrowSelftest(io);
    if (args.len >= 2 and std.mem.eql(u8, args[1], "reputation")) return runReputationSelftest(io);
    const oa1 = try runSelftest(io);
    if (oa1 != 0) return oa1;
    return runEscrowSelftest(io);
}
